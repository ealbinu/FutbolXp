---
export interface Point {
  label: string;
  value: number;
}

interface Props {
  points: Point[];
  color?: string;
  title?: string;
  compact?: boolean;
}

const {
  points = [],
  color = 'var(--accent-blue)',
  title = 'Actividad 7 días',
  compact = false,
} = Astro.props as Props;

const safePoints = points.length > 0 ? points : Array.from({ length: 7 }, (_, i) => ({ label: i === 6 ? 'HOY' : '·', value: 0 }));
const maxValue = Math.max(...safePoints.map((p) => p.value), 1);
const totalValue = safePoints.reduce((sum, p) => sum + p.value, 0);
const peakDay = safePoints.reduce((best, p) => (p.value > best.value ? p : best), safePoints[0]);

const width = compact ? 180 : 260;
const height = compact ? 48 : 64;
const paddingX = compact ? 8 : 12;
const paddingY = compact ? 6 : 8;
const numBars = safePoints.length;
const slotWidth = (width - paddingX * 2) / numBars;
const barWidth = Math.max(slotWidth * 0.55, 2);
const minBarHeight = 2;

const bars = safePoints.map((point, index) => {
  const slot = paddingX + index * slotWidth + (slotWidth - barWidth) / 2;
  const barH = point.value > 0
    ? Math.max(minBarHeight, (point.value / maxValue) * (height - paddingY * 2))
    : minBarHeight;
  const x = slot;
  const y = height - paddingY - barH;
  const isToday = point.label === 'HOY';
  const isActive = point.value > 0;
  return { ...point, x, y, barH, isToday, isActive, centerX: slot + barWidth / 2 };
});
---

<div class:list={['trend-mini-chart', { compact }]}>
  {!compact && <div class="chart-title">{title}</div>}
  <svg viewBox={`0 0 ${width} ${height}`} class="chart-svg" aria-label={title} role="img">
    <!-- baseline -->
    <line
      x1={paddingX} y1={height - paddingY}
      x2={width - paddingX} y2={height - paddingY}
      stroke="#e0e0e0" stroke-width="1"
    />
    {bars.map((bar) => (
      <rect
        x={bar.x}
        y={bar.y}
        width={barWidth}
        height={bar.barH}
        fill={bar.isToday ? color : bar.isActive ? color : '#e0e0e0'}
        opacity={bar.isToday ? 1 : bar.isActive ? 0.65 : 0.3}
        rx="1"
      />
    ))}
  </svg>
  <div class="chart-footer">
    <div class="chart-days">
      {bars.map((bar) => (
        <span class:list={['day-label', { today: bar.isToday, active: bar.isActive }]}>
          {bar.label}
        </span>
      ))}
    </div>
    <div class="chart-summary">
      {totalValue > 0
        ? <><strong>{totalValue}</strong> nota{totalValue !== 1 ? 's' : ''} · pico <strong>{peakDay.value}</strong></>
        : <span class="no-data">sin actividad</span>
      }
    </div>
  </div>
</div>

<style>
  .trend-mini-chart {
    border: 2px solid #000000;
    padding: 0.75rem;
    background: #ffffff;
  }
  .trend-mini-chart.compact {
    padding: 0.6rem;
  }
  .chart-title {
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    color: #666666;
    margin-bottom: 0.35rem;
    letter-spacing: 0.06em;
  }
  .chart-svg {
    width: 100%;
    height: auto;
    display: block;
    margin-bottom: 0.3rem;
  }
  .chart-footer {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .chart-days {
    display: flex;
    justify-content: space-between;
    padding: 0 1px;
  }
  .day-label {
    font-size: 0.52rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #cccccc;
    letter-spacing: 0.03em;
    text-align: center;
    flex: 1;
  }
  .day-label.active {
    color: #888888;
  }
  .day-label.today {
    color: #000000;
    font-weight: 900;
  }
  .chart-summary {
    font-size: 0.62rem;
    color: #888888;
    text-align: right;
    font-weight: 600;
  }
  .chart-summary strong {
    color: #000000;
    font-weight: 900;
  }
  .no-data {
    color: #bbbbbb;
    font-style: italic;
  }
</style>
