---
export interface Point {
  label: string;
  value: number;
}

interface Props {
  points: Point[];
  color?: string;
  title?: string;
  compact?: boolean;
}

const {
  points = [],
  color = 'var(--accent-blue)',
  title = 'Tendencia',
  compact = false,
} = Astro.props as Props;

const safePoints = points.length > 0 ? points : [{ label: 'sin datos', value: 0 }];
const maxValue = Math.max(...safePoints.map((point) => point.value), 1);
const width = compact ? 180 : 260;
const height = compact ? 52 : 72;
const paddingX = compact ? 12 : 16;
const paddingY = compact ? 8 : 12;
const step = safePoints.length > 1 ? (width - paddingX * 2) / (safePoints.length - 1) : 0;

const chartPoints = safePoints.map((point, index) => {
  const x = paddingX + index * step;
  const normalized = point.value / maxValue;
  const y = height - paddingY - normalized * (height - paddingY * 2);
  return { ...point, x, y };
});

const polyline = chartPoints.map((point) => `${point.x},${point.y}`).join(' ');
---

<div class:list={['trend-mini-chart', { compact }]}>
  {!compact && <div class="chart-title">{title}</div>}
  <svg viewBox={`0 0 ${width} ${height}`} class="chart-svg" aria-label={title} role="img">
    <line x1={paddingX} y1={height - paddingY} x2={width - paddingX} y2={height - paddingY} stroke="#000000" stroke-width="2" />
    <polyline points={polyline} fill="none" stroke={color} stroke-width="3" stroke-linecap="square" stroke-linejoin="miter" />
    {chartPoints.map((point) => (
      <g>
        <circle cx={point.x} cy={point.y} r="3.5" fill={color} stroke="#000000" stroke-width="1.5" />
      </g>
    ))}
  </svg>
  <div class="chart-labels">
    {safePoints.map((point) => (
      <div class="chart-label">
        <strong>{point.value}</strong>
        <small>{point.label}</small>
      </div>
    ))}
  </div>
</div>

<style>
  .trend-mini-chart {
    border: 2px solid #000000;
    padding: 0.75rem;
    background: #ffffff;
  }
  .trend-mini-chart.compact {
    padding: 0.6rem;
  }
  .chart-title {
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    color: #666666;
    margin-bottom: 0.35rem;
    letter-spacing: 0.06em;
  }
  .chart-svg {
    width: 100%;
    height: auto;
    display: block;
    margin-bottom: 0.45rem;
  }
  .chart-labels {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.35rem;
  }
  .chart-label strong {
    display: block;
    font-size: 0.82rem;
    font-weight: 900;
  }
  .chart-label small {
    display: block;
    font-size: 0.6rem;
    text-transform: uppercase;
    color: #666666;
    font-weight: 800;
    line-height: 1.25;
  }
</style>
