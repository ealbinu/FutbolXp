---
export interface Props {
  teams: any[];
}
const { teams } = Astro.props;
---
<div class="subscribe-container">
  <h3>Suscríbete</h3>
  <p>Recibe las últimas noticias de tus selecciones favoritas directamente en tu correo.</p>
  <form id="subscribe-form" class="subscribe-form">
    <div class="form-group">
      <label for="email">Correo electrónico:</label>
      <input type="email" id="email" name="email" required placeholder="tu@correo.com" />
    </div>
    <div class="form-group">
      <label>Selecciona tus equipos de interés:</label>
      <div class="teams-checkboxes">
        {teams.filter(t => t.data.qualified).map(team => (
          <label class="team-cb">
            <input type="checkbox" name="teams" value={team.data.id} />
            {team.data.name}
          </label>
        ))}
      </div>
    </div>
    <button type="submit" class="btn btn-primary" id="sub-btn">Suscribirse →</button>
    <div id="sub-msg" class="msg"></div>
  </form>
</div>

<script>
  const form = document.getElementById('subscribe-form') as HTMLFormElement;
  const msg = document.getElementById('sub-msg');
  const btn = document.getElementById('sub-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!msg || !btn) return;
    btn.disabled = true;
    btn.textContent = 'Enviando...';
    
    const formData = new FormData(form);
    const email = formData.get('email');
    const teams = formData.getAll('teams');

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, teams })
      });
      const data = await res.json();
      if (res.ok) {
        msg.textContent = '¡Suscripción exitosa!';
        msg.className = 'msg success';
        form.reset();
      } else {
        msg.textContent = data.error || 'Ocurrió un error.';
        msg.className = 'msg error';
      }
    } catch(err) {
      msg.textContent = 'Error de conexión.';
      msg.className = 'msg error';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Suscribirse →';
    }
  });
</script>

<style>
  .subscribe-container {
    background: #ffffff;
    border: 3px solid #000000;
    padding: 2rem;
    margin: 3rem auto;
    max-width: 800px;
  }
  .subscribe-container h3 {
    margin-bottom: 0.5rem;
    color: #000000;
    font-size: 1.3rem;
  }
  .subscribe-container p {
    color: #333333;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  .form-group {
    margin-bottom: 1.5rem;
  }
  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  input[type="email"] {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 2px solid #000000;
    background: #ffffff;
    color: #000000;
    font-family: 'Google Sans Flex Text', sans-serif;
    font-size: 0.9rem;
  }
  input[type="email"]:focus {
    outline: 3px solid #000000;
    outline-offset: 2px;
  }
  .teams-checkboxes {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 0.5rem;
    max-height: 200px;
    overflow-y: auto;
    padding: 1rem;
    background: #ffffff;
    border: 2px solid #000000;
  }
  .team-cb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 500;
  }
  .team-cb input[type="checkbox"] {
    accent-color: #000000;
    width: 16px;
    height: 16px;
  }
  .msg {
    margin-top: 1rem;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
  }
  .msg.success { color: #000000; }
  .msg.error { color: #000000; text-decoration: underline; }
</style>
