---
import Layout from '../../layouts/Layout.astro';
import { getEntry, getCollection } from 'astro:content';
import { getNewsByPlayer } from '../../lib/pocketbase';

export const prerender = false;

const { id } = Astro.params;
const entry = await getEntry('players', id as any);

if (!entry) {
  return Astro.redirect('/404');
}

const player = entry.data;

// Fetch real news from PocketBase
const realNews = await getNewsByPlayer(player.id, 10);

// Combine with static news (optional, but real news first)
const staticNews = player.news || [];
const allNews = [...realNews, ...staticNews].slice(0, 15);

if (allNews.length === 0) {
  return Astro.redirect('/jugadores');
}

const allTeams = await getCollection('teams');
const team = allTeams.find(t => t.data.id === player.team);

const formatDate = (dateString: string) => {
  try {
    return new Intl.DateTimeFormat('es-MX', { day: '2-digit', month: 'short', year: 'numeric' }).format(new Date(dateString));
  } catch { return ''; }
};

const playerUrl = `https://futbolexperto.com/jugador/${player.id}`;
const playerSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://futbolexperto.com/' },
        { '@type': 'ListItem', position: 2, name: 'Jugadores', item: 'https://futbolexperto.com/jugadores' },
        { '@type': 'ListItem', position: 3, name: player.name, item: playerUrl },
      ],
    },
    {
      '@type': 'Person',
      name: player.name,
      url: playerUrl,
      nationality: player.nationality,
      jobTitle: player.position,
      image: player.photo || undefined,
      memberOf: team ? { '@type': 'SportsTeam', name: team.data.name, url: `https://futbolexperto.com/equipo/${team.data.id}` } : undefined,
      description: `Perfil y noticias de ${player.name} en FutbolExperto para Futbol 2026.`,
    },
  ],
};
---

<Layout title={`${player.name} - FutbolExperto`} description={`Perfil, noticias y contexto de ${player.name}${team ? `, jugador de ${team.data.name}` : ''}, para Futbol 2026.`}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(playerSchema)} />
  </Fragment>
  <main class="container section">
    <a href="/jugadores" class="back-link">&larr; Todos los jugadores</a>

    <div class="profile-card">
      <div class="profile-avatar">
        {player.photo ? (
          <img src={player.photo} alt={player.name} />
        ) : (
          <span class="avatar-letter">{player.name.charAt(0)}</span>
        )}
      </div>
      <div class="profile-info">
        <h1>{player.name}</h1>
        <div class="profile-badges">
          <span class="badge badge-primary">{player.position}</span>
          {player.number && <span class="badge badge-primary">#{player.number}</span>}
          <span class="badge badge-primary">{player.nationality}</span>
          <span class="badge accent-blue">{player.status || 'prelista'}</span>
          {player.isCaptain && <span class="badge accent-amber">Capitán</span>}
        </div>
        {team && (
          <a href={`/equipo/${team.data.id}`} class="team-link">
            <img src={team.data.flag} alt={team.data.name} class="team-flag-sm" />
            {team.data.name}
          </a>
        )}
      </div>
    </div>

    <div class="content-grid">
      <div class="main-col">
        <h2 class="section-title">Noticias</h2>
        {allNews.length > 0 ? (
          <div class="news-list">
            {allNews.map((item: any) => (
              <a href={item.id ? `/noticia/${item.id}` : item.url} target={item.id ? "_self" : "_blank"} rel="noopener noreferrer" class="news-card">
                <div class="title">{item.title}</div>
                <div class="meta">
                  <span class="source">{item.source}</span>
                  <time datetime={item.published}>{formatDate(item.published)}</time>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="empty-state">No hay noticias para este jugador.</div>
        )}
      </div>

      <aside class="sidebar">
        <div class="sidebar-section">
          <h3 class="sidebar-title">Info</h3>
          <div class="info-grid">
            <div class="info-item">
              <span class="info-label">Posicion</span>
              <span class="info-value">{player.position}</span>
            </div>
            <div class="info-item">
              <span class="info-label">Estado</span>
              <span class="info-value">{player.status || 'prelista'}</span>
            </div>
            {player.number && (
              <div class="info-item">
                <span class="info-label">Numero</span>
                <span class="info-value">#{player.number}</span>
              </div>
            )}
            <div class="info-item">
              <span class="info-label">Nacionalidad</span>
              <span class="info-value">{player.nationality}</span>
            </div>
            {player.club && (
              <div class="info-item">
                <span class="info-label">Club</span>
                <span class="info-value">{player.club}</span>
              </div>
            )}
            {player.birth && (
              <div class="info-item">
                <span class="info-label">Nacimiento</span>
                <span class="info-value">{formatDate(player.birth)}</span>
              </div>
            )}
            {player.lastVerified && (
              <div class="info-item">
                <span class="info-label">Verificado</span>
                <span class="info-value">{formatDate(player.lastVerified)}</span>
              </div>
            )}
            {typeof player.caps === 'number' && (
              <div class="info-item">
                <span class="info-label">Internacionales</span>
                <span class="info-value">{player.caps}</span>
              </div>
            )}
            {typeof player.goals === 'number' && (
              <div class="info-item">
                <span class="info-label">Goles</span>
                <span class="info-value">{player.goals}</span>
              </div>
            )}
          </div>
        </div>

        {(player.source || player.aliases.length > 0) && (
          <div class="sidebar-section">
            <h3 class="sidebar-title">Seguimiento editorial</h3>
            <div class="info-grid">
              {player.source && (
                <div class="info-item">
                  <span class="info-label">Fuente</span>
                  {player.sourceUrl ? (
                    <a href={player.sourceUrl} target="_blank" rel="noopener noreferrer" class="info-value info-link">{player.source}</a>
                  ) : (
                    <span class="info-value">{player.source}</span>
                  )}
                </div>
              )}
              {player.aliases.length > 0 && (
                <div class="info-item aliases-item">
                  <span class="info-label">Alias</span>
                  <span class="info-value">{player.aliases.join(' • ')}</span>
                </div>
              )}
            </div>
          </div>
        )}

        {(player.social.twitter || player.social.instagram || player.social.tiktok || player.social.facebook) && (
          <div class="sidebar-section">
            <h3 class="sidebar-title">Redes Sociales</h3>
            <div class="social-list">
              {player.social.twitter && (
                <a href={player.social.twitter} target="_blank" rel="noopener noreferrer" class="social-btn twitter">Twitter / X</a>
              )}
              {player.social.instagram && (
                <a href={player.social.instagram} target="_blank" rel="noopener noreferrer" class="social-btn instagram">Instagram</a>
              )}
              {player.social.tiktok && (
                <a href={player.social.tiktok} target="_blank" rel="noopener noreferrer" class="social-btn tiktok">TikTok</a>
              )}
              {player.social.facebook && (
                <a href={player.social.facebook} target="_blank" rel="noopener noreferrer" class="social-btn facebook">Facebook</a>
              )}
            </div>
          </div>
        )}
      </aside>
    </div>
  </main>
</Layout>

<style>
  .back-link {
    display: inline-block;
    color: #000000;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .back-link:hover { text-decoration-thickness: 3px; }

  .profile-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem;
    background: #ffffff;
    border: 3px solid #000000;
    margin-bottom: 2.5rem;
  }
  .profile-avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: #f0f0f0;
    border: 3px solid #000000;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .profile-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .avatar-letter { font-size: 2.5rem; font-weight: 900; color: #666666; }
  .profile-info h1 { font-size: 2rem; margin-bottom: 0.5rem; }
  .profile-badges { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
  .team-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #000000;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .team-flag-sm { width: 20px; height: 20px; border-radius: 50%; object-fit: cover; border: 1px solid #000000; }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2rem;
    align-items: start;
  }
  .news-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .sidebar-section {
    background: #ffffff;
    border: 2px solid #000000;
    padding: 1.25rem;
  }
  .sidebar-title {
    font-size: 0.85rem;
    color: #000000;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #000000;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .info-grid { display: flex; flex-direction: column; gap: 0.75rem; }
  .info-item { display: flex; justify-content: space-between; gap: 0.75rem; }
  .aliases-item {
    align-items: flex-start;
    flex-direction: column;
  }
  .info-label { font-size: 0.8rem; color: #666666; text-transform: uppercase; font-weight: 600; }
  .info-value { font-size: 0.8rem; font-weight: 700; text-align: right; }
  .info-link {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .aliases-item .info-value {
    text-align: left;
  }

  .social-list { display: flex; flex-direction: column; gap: 0.4rem; }
  .social-btn {
    display: block;
    padding: 0.6rem 1rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    background: #ffffff;
    border: 2px solid #000000;
    color: #000000;
    transition: all 0.1s;
  }
  .social-btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 2px 2px 0px #000000;
  }
  .social-btn.twitter { background: #ffffff !important; color: #000000 !important; }
  .social-btn.instagram { background: #ffffff !important; color: #000000 !important; }
  .social-btn.tiktok { background: #ffffff !important; color: #000000 !important; }
  .social-btn.facebook { background: #ffffff !important; color: #000000 !important; }

  @media (max-width: 768px) {
    .content-grid { grid-template-columns: 1fr; }
    .profile-card { flex-direction: column; text-align: center; padding: 1.5rem 1.25rem; }
    .profile-badges { justify-content: center; }
    .profile-avatar { width: 80px; height: 80px; }
    .profile-info h1 { font-size: 1.5rem; }
    .back-link { margin-bottom: 1rem; }
  }
</style>

