---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const players = await getCollection('players');
  return players.map((player) => ({
    params: { id: player.data.id },
    props: { player: player.data },
  }));
}

const { player } = Astro.props;

const allTeams = await getCollection('teams');
const team = allTeams.find(t => t.data.id === player.team);

const formatDate = (dateString: string) => {
  try {
    return new Intl.DateTimeFormat('es-MX', { day: '2-digit', month: 'short', year: 'numeric' }).format(new Date(dateString));
  } catch { return ''; }
};
---

<Layout title={`${player.name} - FutbolXP`}>
  <main class="container section">
    <a href="/jugadores" class="back-link">&larr; Todos los jugadores</a>

    <div class="profile-card">
      <div class="profile-avatar">
        {player.photo ? (
          <img src={player.photo} alt={player.name} />
        ) : (
          <span class="avatar-letter">{player.name.charAt(0)}</span>
        )}
      </div>
      <div class="profile-info">
        <h1>{player.name}</h1>
        <div class="profile-badges">
          <span class="badge badge-primary">{player.position}</span>
          {player.number && <span class="badge badge-primary">#{player.number}</span>}
          <span class="badge badge-primary">{player.nationality}</span>
        </div>
        {team && (
          <a href={`/equipo/${team.data.id}`} class="team-link">
            <img src={team.data.flag} alt={team.data.name} class="team-flag-sm" />
            {team.data.name}
          </a>
        )}
      </div>
    </div>

    <div class="content-grid">
      <div class="main-col">
        <h2 class="section-title">Noticias</h2>
        {player.news && player.news.length > 0 ? (
          <div class="news-list">
            {player.news.map((item) => (
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="news-card">
                <div class="title">{item.title}</div>
                <div class="meta">
                  <span class="source">{item.source}</span>
                  <time datetime={item.published}>{formatDate(item.published)}</time>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="empty-state">No hay noticias para este jugador.</div>
        )}
      </div>

      <aside class="sidebar">
        <div class="sidebar-section">
          <h3 class="sidebar-title">Info</h3>
          <div class="info-grid">
            <div class="info-item">
              <span class="info-label">Posicion</span>
              <span class="info-value">{player.position}</span>
            </div>
            {player.number && (
              <div class="info-item">
                <span class="info-label">Numero</span>
                <span class="info-value">#{player.number}</span>
              </div>
            )}
            <div class="info-item">
              <span class="info-label">Nacionalidad</span>
              <span class="info-value">{player.nationality}</span>
            </div>
            {player.birth && (
              <div class="info-item">
                <span class="info-label">Nacimiento</span>
                <span class="info-value">{formatDate(player.birth)}</span>
              </div>
            )}
          </div>
        </div>

        {(player.social.twitter || player.social.instagram || player.social.tiktok || player.social.facebook) && (
          <div class="sidebar-section">
            <h3 class="sidebar-title">Redes Sociales</h3>
            <div class="social-list">
              {player.social.twitter && (
                <a href={player.social.twitter} target="_blank" rel="noopener noreferrer" class="social-btn twitter">Twitter / X</a>
              )}
              {player.social.instagram && (
                <a href={player.social.instagram} target="_blank" rel="noopener noreferrer" class="social-btn instagram">Instagram</a>
              )}
              {player.social.tiktok && (
                <a href={player.social.tiktok} target="_blank" rel="noopener noreferrer" class="social-btn tiktok">TikTok</a>
              )}
              {player.social.facebook && (
                <a href={player.social.facebook} target="_blank" rel="noopener noreferrer" class="social-btn facebook">Facebook</a>
              )}
            </div>
          </div>
        )}
      </aside>
    </div>
  </main>
</Layout>

<style>
  .back-link {
    display: inline-block;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-bottom: 1.25rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--color-primary-light); }

  .profile-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: 2.5rem;
  }
  .profile-avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: var(--color-surface-2);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .profile-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .avatar-letter { font-size: 2.5rem; font-weight: 800; color: var(--color-text-muted); }
  .profile-info h1 { font-size: 2rem; margin-bottom: 0.5rem; }
  .profile-badges { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
  .team-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-primary-light);
    font-weight: 500;
    font-size: 0.9rem;
  }
  .team-flag-sm { width: 20px; height: 20px; border-radius: 50%; object-fit: cover; }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2rem;
    align-items: start;
  }
  .news-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .sidebar-section {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
  }
  .sidebar-title {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .info-grid { display: flex; flex-direction: column; gap: 0.75rem; }
  .info-item { display: flex; justify-content: space-between; }
  .info-label { font-size: 0.85rem; color: var(--color-text-muted); }
  .info-value { font-size: 0.85rem; font-weight: 600; }

  .social-list { display: flex; flex-direction: column; gap: 0.4rem; }
  .social-btn {
    display: block;
    padding: 0.6rem 1rem;
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    transition: opacity 0.2s;
  }
  .social-btn:hover { opacity: 0.85; }
  .social-btn.twitter { background: #1d9bf0; color: white; }
  .social-btn.instagram { background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); color: white; }
  .social-btn.tiktok { background: #010101; color: white; }
  .social-btn.facebook { background: #1877f2; color: white; }

  @media (max-width: 768px) {
    .content-grid { grid-template-columns: 1fr; }
    .profile-card { flex-direction: column; text-align: center; }
    .profile-badges { justify-content: center; }
    .profile-avatar { width: 80px; height: 80px; }
    .profile-info h1 { font-size: 1.5rem; }
  }
</style>
