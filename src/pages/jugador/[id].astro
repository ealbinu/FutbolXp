import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import type { Player } from '../../content/config';

export async function getStaticPaths() {
  const players = await getCollection('players');
  return players.map((player) => ({
    params: { id: player.data.id },
    props: { player: player.data },
  }));
}

const { player } = Astro.props;

// Placeholder for social media posts - in a real implementation, this would fetch from APIs
const socialPosts = [
  {
    platform: 'twitter',
    content: '¡Gran victoria hoy! Seguimos trabajando para el Mundial 2026 💪🇲🇽 #FutbolExperto2026',
    date: '2025-03-12T15:30:00Z',
    likes: 15420,
    retweets: 3420,
  },
  {
    platform: 'instagram',
    content: 'Entrenamiento de hoy con el equipo. ¡Listos para el próximo desafío! ⚽',
    date: '2025-03-11T18:00:00Z',
    likes: 28500,
    comments: 890,
  },
];

const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return new Intl.DateTimeFormat('es-ES', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  }).format(date);
};

const getTeam = async (teamId: string) => {
  const teams = await getCollection('teams');
  return teams.find(t => t.data.id === teamId);
};
</script>

<Layout title={`${player.name} - Fútbol Experto 2026`}>
  <main class="container section">
    <div class="player-profile" style="max-width: 800px; margin: 0 auto;">
      <div class="player-header" style="display: flex; gap: 2rem; margin-bottom: 2rem; padding: 2rem; background: var(--gradient-card); border-radius: 16px; border: 1px solid var(--color-border);">
        <div style="width: 120px; height: 120px; border-radius: 50%; background: var(--color-surface); flex-shrink: 0; overflow: hidden;">
          {player.photo ? (
            <img src={player.photo} alt={player.name} style="width: 100%; height: 100%; object-fit: cover;" />
          ) : (
            <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: 800; color: var(--color-text-muted);">
              {player.name.charAt(0)}
            </div>
