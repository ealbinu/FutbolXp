---
import Layout from '../layouts/Layout.astro';
import { getAllNews } from '../lib/pocketbase';
import { getCollection } from 'astro:content';

const url = new URL(Astro.request.url);
const page = parseInt(url.searchParams.get('page') || '1');
const perPage = 20;

// Fetch news from PocketBase
let newsData = { items: [] as any[], totalPages: 0, totalItems: 0 };
try {
  newsData = await getAllNews(page, perPage);
} catch (e) {
  console.error('Error fetching news:', e);
}

// Also gather static news from teams as fallback - only if on first page
let staticNews: any[] = [];
if (page === 1) {
  const allTeams = await getCollection('teams');
  staticNews = allTeams.flatMap(t =>
    (t.data.news || []).map(n => ({ ...n, teamId: t.data.id, teamName: t.data.name }))
  ).sort((a, b) => new Date(b.published).getTime() - new Date(a.published).getTime());
}

// Merge: PocketBase first, then static (deduped by url)
const pbUrls = new Set(newsData.items.map((n: any) => n.url));
const allNews = [
  ...newsData.items,
  ...staticNews.filter(n => !pbUrls.has(n.url)).slice(0, 50),
];


const formatRelative = (dateString: string) => {
  try {
    const diff = Date.now() - new Date(dateString).getTime();
    const hours = Math.floor(diff / 3600000);
    if (hours < 1) return 'Hace minutos';
    if (hours < 24) return `Hace ${hours}h`;
    const days = Math.floor(hours / 24);
    if (days === 1) return 'Ayer';
    if (days < 7) return `Hace ${days} dias`;
    return new Intl.DateTimeFormat('es-MX', { day: '2-digit', month: 'short' }).format(new Date(dateString));
  } catch { return ''; }
};

const totalPages = newsData.totalPages;
const hasNextPage = page < totalPages;
const hasPrevPage = page > 1;
---

<Layout title="Noticias - FutbolExperto">
  <main class="container section">
    <div class="page-header">
      <h1>Noticias del Mundial 2026</h1>
      <p class="page-desc">
        <span class="pulse"></span>
        ¡Analizando el pulso del mundial! &bull; Página {page} de {totalPages || 1}
      </p>
    </div>

    {allNews.length > 0 ? (
      <>
        <div class="news-feed">
          {allNews.map((item: any) => (
            <div class="news-item">
              <div class="news-content">
                <div class="news-header">
                  <span class="news-source">{item.source}</span>
                  {(item.teamName || item.teamId) && (
                    <span class="news-team">{item.teamName || item.teamId}</span>
                  )}
                </div>
                <h3 class="news-title">{item.title}</h3>
                {item.contentSnippet && (
                  <p class="news-snippet">{item.contentSnippet.slice(0, 150)}...</p>
                )}
                <div class="news-footer">
                  <time datetime={item.published}>{formatRelative(item.published)}</time>
                </div>
                <a href={item.id ? `/noticia/${item.id}` : item.url} target={item.id ? "_self" : "_blank"} rel="noopener noreferrer" class="read-more-link">Visitar nota &rarr;</a>
              </div>
            </div>
          ))}
        </div>

        {totalPages > 1 && (
          <div class="pagination">
            {hasPrevPage ? (
              <a href={`/noticias?page=${page - 1}`} class="btn btn-primary pagination-btn">
                &larr; Anterior
              </a>
            ) : (
              <span class="btn btn-disabled pagination-btn">&larr; Anterior</span>
            )}
            
            <div class="page-numbers">
              Página <strong>{page}</strong> de {totalPages}
            </div>

            {hasNextPage ? (
              <a href={`/noticias?page=${page + 1}`} class="btn btn-primary pagination-btn">
                Siguiente &rarr;
              </a>
            ) : (
              <span class="btn btn-disabled pagination-btn">Siguiente &rarr;</span>
            )}
          </div>
        )}
      </>
    ) : (
      <div class="empty-state">
        <p>No hay noticias disponibles en esta página.</p>
        <a href="/noticias" class="btn btn-primary">Volver al inicio</a>
      </div>
    )}
  </main>
</Layout>

<script is:inline>
  document.addEventListener('click', (e) => {
    const link = e.target.closest('.read-more-link');
    if (link && link.getAttribute('target') !== '_blank') {
      const newsItem = link.closest('.news-item') || link.closest('.news-card');
      const title = newsItem?.querySelector('.news-title')?.textContent || newsItem?.querySelector('.title')?.textContent;
      
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        'event': 'content_interaction',
        'interaction_type': 'internal_news_view',
        'content_title': title
      });
    }
  });
</script>

<style>
  .page-header { margin-bottom: 2rem; }
  .page-header h1 { font-size: 2.5rem; margin-bottom: 0.25rem; }
  .page-desc {
    color: #333333;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .news-feed {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .news-item {
    display: block;
    padding: 1.5rem 2rem;
    background: #ffffff;
    border: 3px solid #000000;
    transition: all 0.1s;
  }
  .news-item:hover {
    transform: translate(-4px, -4px);
  }

  .news-header {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    align-items: center;
  }
  .news-source {
    font-size: 0.85rem;
    font-weight: 800;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .news-team {
    font-size: 0.75rem;
    color: #000000;
    padding: 0.2rem 0.6rem;
    background: transparent;
    border: 2px solid #000000;
    font-weight: 700;
    text-transform: uppercase;
  }

  .news-title {
    font-family: 'Google Sans Flex Text', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    line-height: 1.25;
    text-transform: none;
  }

  .news-snippet {
    font-size: 1rem;
    color: #333333;
    line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-footer {
    font-size: 0.9rem;
    color: #666666;
    margin-bottom: 1.25rem;
    font-weight: 600;
  }

  .read-more-link {
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.9rem;
    text-decoration: underline;
    text-underline-offset: 4px;
    color: #000000;
  }
  .read-more-link:hover {
    text-decoration-thickness: 3px;
  }

  /* Pagination styles */
  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 3px solid #000000;
  }

  .page-numbers {
    font-size: 1rem;
    font-weight: 600;
  }

  .pagination-btn {
    min-width: 120px;
    text-align: center;
  }

  .btn-disabled {
    opacity: 0.3;
    pointer-events: none;
    border-color: #999;
    color: #999;
  }

  @media (max-width: 768px) {
    .page-header h1 { font-size: 2rem; }
    .news-item { padding: 1.25rem; }
    .news-title { font-size: 1.25rem; }
    .pagination {
        flex-direction: column;
        gap: 1.5rem;
    }
    .pagination-btn { width: 100%; }
  }
</style>
