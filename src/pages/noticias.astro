---
import Layout from '../layouts/Layout.astro';
import { getAllNews } from '../lib/pocketbase';
import { getCollection } from 'astro:content';

// Fetch news from PocketBase
let newsData = { items: [] as any[], totalPages: 0, totalItems: 0 };
try {
  newsData = await getAllNews(1, 50);
} catch (e) {
  console.error('Error fetching news:', e);
}

// Also gather static news from teams as fallback
const allTeams = await getCollection('teams');
const staticNews = allTeams.flatMap(t =>
  (t.data.news || []).map(n => ({ ...n, teamId: t.data.id, teamName: t.data.name }))
).sort((a, b) => new Date(b.published).getTime() - new Date(a.published).getTime());

// Merge: PocketBase first, then static (deduped by url)
const pbUrls = new Set(newsData.items.map((n: any) => n.url));
const allNews = [
  ...newsData.items,
  ...staticNews.filter(n => !pbUrls.has(n.url)).slice(0, 50),
];

const formatDate = (dateString: string) => {
  try {
    return new Intl.DateTimeFormat('es-MX', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }).format(new Date(dateString));
  } catch { return ''; }
};

const formatRelative = (dateString: string) => {
  try {
    const diff = Date.now() - new Date(dateString).getTime();
    const hours = Math.floor(diff / 3600000);
    if (hours < 1) return 'Hace minutos';
    if (hours < 24) return `Hace ${hours}h`;
    const days = Math.floor(hours / 24);
    if (days === 1) return 'Ayer';
    if (days < 7) return `Hace ${days} dias`;
    return formatDate(dateString);
  } catch { return ''; }
};
---

<Layout title="Noticias - FutbolXP">
  <main class="container section">
    <div class="page-header">
      <h1>Noticias del Mundial 2026</h1>
      <p class="page-desc">
        <span class="pulse"></span>
        Actualizadas automaticamente cada 3 horas &bull; {allNews.length} noticias
      </p>
    </div>

    {allNews.length > 0 ? (
      <div class="news-feed">
        {allNews.map((item: any, i: number) => (
          <a href={item.url} target="_blank" rel="noopener noreferrer" class="news-item">
            <div class="news-content">
              <div class="news-header">
                <span class="news-source">{item.source}</span>
                {(item.teamName || item.teamId) && (
                  <span class="news-team">{item.teamName || item.teamId}</span>
                )}
              </div>
              <h3 class="news-title">{item.title}</h3>
              {item.contentSnippet && (
                <p class="news-snippet">{item.contentSnippet.slice(0, 150)}...</p>
              )}
              <div class="news-footer">
                <time datetime={item.published}>{formatRelative(item.published)}</time>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p>No hay noticias disponibles. Las noticias se actualizan cada 3 horas.</p>
      </div>
    )}
  </main>
</Layout>

<style>
  .page-header { margin-bottom: 2rem; }
  .page-header h1 { font-size: 2rem; margin-bottom: 0.25rem; }
  .page-desc {
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .news-feed {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .news-item {
    display: block;
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all 0.2s;
  }
  .news-item:hover {
    border-color: var(--color-primary);
    background: var(--color-surface-2);
  }

  .news-header {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .news-source {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-primary-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .news-team {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    padding: 0.1rem 0.5rem;
    background: var(--color-surface-2);
    border-radius: 100px;
  }

  .news-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
    line-height: 1.3;
  }

  .news-snippet {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-footer {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
</style>
