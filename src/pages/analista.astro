---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getLatestNews } from '../lib/pocketbase';
import { buildAnalystCards, buildAnalystComparison, buildAnalystForecastBoards, buildAnalystTiers } from '../lib/analyst';
import TrendMiniChart from '../components/TrendMiniChart.astro';

export const prerender = false;

const allTeams = await getCollection('teams');
let latestNews: any[] = [];

try {
  latestNews = await getLatestNews(180);
} catch (e) {
  console.error('Error fetching latest news for analyst:', e);
}

const analystCards = buildAnalystCards(allTeams, latestNews, 40);
const qualifiedCards = analystCards.filter((card) => card.qualified);
const groups = [...new Set(qualifiedCards.map((card) => card.group).filter(Boolean))].sort();
const continents = [...new Set(qualifiedCards.map((card) => card.continent))].sort();
const topCard = qualifiedCards[0];
const avgTrend = qualifiedCards.length > 0 ? Math.round(qualifiedCards.reduce((acc, card) => acc + card.trendScore, 0) / qualifiedCards.length) : 0;
const featuredComparison = qualifiedCards.length >= 2 ? buildAnalystComparison(qualifiedCards[0], qualifiedCards[1]) : null;
const analystTiers = buildAnalystTiers(qualifiedCards).slice(0, 2);
const forecastBoards = buildAnalystForecastBoards(qualifiedCards).slice(0, 1);

const accentClass = (value: string) => {
  const normalized = value.toLowerCase();
  if (normalized.includes('positivo') || normalized.includes('ascenso') || normalized.includes('favoritos')) return 'accent-green';
  if (normalized.includes('alerta') || normalized.includes('riesgo') || normalized.includes('vigilancia')) return 'accent-rose';
  if (normalized.includes('pulso') || normalized.includes('ritmo') || normalized.includes('semifinal')) return 'accent-blue';
  if (normalized.includes('tono') || normalized.includes('figura') || normalized.includes('tapados') || normalized.includes('caballos')) return 'accent-violet';
  return 'accent-amber';
};

const formatRelative = (dateString: string) => {
  try {
    const diff = Date.now() - new Date(dateString).getTime();
    const hours = Math.floor(diff / 3600000);
    if (hours < 1) return 'Hace minutos';
    if (hours < 24) return `Hace ${hours}h`;
    const days = Math.floor(hours / 24);
    if (days === 1) return 'Ayer';
    if (days < 7) return `Hace ${days} días`;
    return new Intl.DateTimeFormat('es-MX', { day: '2-digit', month: 'short' }).format(new Date(dateString));
  } catch {
    return '';
  }
};
---

<Layout title="Analista - FutbolExperto" description="Tarjetas de análisis automáticas a partir de las últimas noticias del Mundial 2026.">
  <main class="container section">
    <section class="hero-block">
      <div>
        <div class="eyebrow">ANALISTA V5</div>
        <h1>Radar inteligente de selecciones</h1>
        <p class="page-desc">
          Cruza noticias recientes, detecta temas dominantes y ordena a los participantes con mayor tendencia mediática del Mundial.
        </p>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <strong>{qualifiedCards.length}</strong>
          <span>selecciones con análisis</span>
        </div>
        <div class="hero-stat">
          <strong>{topCard ? topCard.teamName : '--'}</strong>
          <span>más caliente del radar</span>
        </div>
        <div class="hero-stat">
          <strong>{avgTrend}</strong>
          <span>tendencia promedio</span>
        </div>
      </div>
    </section>

    {qualifiedCards.length > 0 ? (
      <>
        <section class="toolbar card">
          <div class="toolbar-group filters-group">
            <select id="groupFilter" class="toolbar-select">
              <option value="">Todos los grupos</option>
              {groups.map((group) => (
                <option value={group}>Grupo {group}</option>
              ))}
            </select>
            <select id="continentFilter" class="toolbar-select">
              <option value="">Todos los continentes</option>
              {continents.map((continent) => (
                <option value={continent}>{continent}</option>
              ))}
            </select>
            <select id="toneFilter" class="toolbar-select">
              <option value="">Todos los tonos</option>
              <option value="Positivo">Positivo</option>
              <option value="Mixto">Mixto</option>
              <option value="Atento">Atento</option>
            </select>
          </div>
          <div class="toolbar-group sort-group">
            <select id="sortFilter" class="toolbar-select">
              <option value="trend">Ordenar por tendencia</option>
              <option value="recent">Más recientes</option>
              <option value="volume">Mayor volumen</option>
              <option value="name">Nombre</option>
            </select>
            <a href="/analista/comparar" class="btn btn-ghost toolbar-link">Comparar</a>
            <div class="results-counter" id="resultsCounter">{qualifiedCards.length} selecciones</div>
          </div>
        </section>

        <section class="top-strip">
          {qualifiedCards.slice(0, 5).map((card, index) => (
            <a href={`#analyst-${card.teamId}`} class="top-item">
              <span class="top-rank">#{index + 1}</span>
              <span class="top-name">{card.teamName}</span>
              <span class="top-score">{card.trendScore}</span>
            </a>
          ))}
        </section>

        {featuredComparison && (
          <section class="comparison card">
            <div class="comparison-head">
              <div>
                <div class="eyebrow">Comparador</div>
                <h2>{featuredComparison.left.teamName} vs {featuredComparison.right.teamName}</h2>
              </div>
              <div class="comparison-badges">
                <span class:list={['mini-badge', accentClass(featuredComparison.left.editorialBadge)]}>{featuredComparison.left.editorialBadge}</span>
                <span class:list={['mini-badge', accentClass(featuredComparison.right.editorialBadge)]}>{featuredComparison.right.editorialBadge}</span>
              </div>
            </div>
            <p class="comparison-summary">{featuredComparison.summary}</p>
            <div class="comparison-grid">
              <div class="comparison-team-box">
                <strong>{featuredComparison.left.teamName}</strong>
                <span>{featuredComparison.left.trendScore} pts • {featuredComparison.left.themes.join(' / ')}</span>
              </div>
              <div class="comparison-team-box">
                <strong>{featuredComparison.right.teamName}</strong>
                <span>{featuredComparison.right.trendScore} pts • {featuredComparison.right.themes.join(' / ')}</span>
              </div>
            </div>
            <ul class="comparison-list">
              {featuredComparison.advantages.map((item) => (
                <li>{item}</li>
              ))}
            </ul>

            <div class="custom-compare">
              <div class="subsection-title">Compara dos selecciones del radar</div>
              <div class="custom-compare-controls">
                <select id="compareLeft" class="toolbar-select">
                  {qualifiedCards.map((card) => (
                    <option value={card.teamId} selected={featuredComparison.left.teamId === card.teamId}>{card.teamName}</option>
                  ))}
                </select>
                <select id="compareRight" class="toolbar-select">
                  {qualifiedCards.map((card) => (
                    <option value={card.teamId} selected={featuredComparison.right.teamId === card.teamId}>{card.teamName}</option>
                  ))}
                </select>
              </div>
              <div class="custom-compare-result card" id="customCompareResult"
                data-cards={JSON.stringify(qualifiedCards.map((card) => ({
                  teamId: card.teamId,
                  teamName: card.teamName,
                  trendScore: card.trendScore,
                  editorialBadge: card.editorialBadge,
                  strengths: card.strengths,
                  themes: card.themes,
                  momentum: card.momentum,
                })))}>
                <strong>{featuredComparison.left.teamName} vs {featuredComparison.right.teamName}</strong>
                <p>{featuredComparison.summary}</p>
              </div>
            </div>
          </section>
        )}

        {analystTiers.length > 0 && (
          <section class="tiers-grid">
            {analystTiers.map((tier) => (
              <article class="tier-card card">
                <div class:list={['eyebrow', accentClass(tier.title)]}>Panel editorial</div>
                <h3>{tier.title}</h3>
                <p>{tier.description}</p>
                <div class="tier-list">
                  {tier.teams.map((team) => (
                    <a href={`/analista/${team.teamId}`} class="tier-item">
                      <span>{team.teamName}</span>
                      <small>{team.trendScore} pts • {team.editorialBadge}</small>
                    </a>
                  ))}
                </div>
              </article>
            ))}
          </section>
        )}

        {forecastBoards.length > 0 && (
          <section class="forecast-grid">
            {forecastBoards.map((board) => (
              <article class="forecast-card card">
                <div class:list={['eyebrow', accentClass(board.title)]}>Predicción editorial</div>
                <h3>{board.title}</h3>
                <p>{board.description}</p>
                <div class="forecast-list">
                  {board.teams.map((team, index) => (
                    <a href={`/analista/${team.teamId}`} class="forecast-item">
                      <span>#{index + 1} {team.teamName}</span>
                      <small>{team.trendScore} pts • {team.trendDirection} • {team.editorialBadge}</small>
                    </a>
                  ))}
                </div>
              </article>
            ))}
          </section>
        )}

        <div class="analyst-grid" id="analystGrid">
          {qualifiedCards.map((card, index) => (
            <article
              id={`analyst-${card.teamId}`}
              class="analyst-card card"
              data-group={card.group || ''}
              data-continent={card.continent}
              data-tone={card.tone}
              data-trend={card.trendScore}
              data-recent={new Date(card.latestPublished).getTime()}
              data-volume={card.newsCount}
              data-name={card.teamName.toLowerCase()}
            >
              <div class="card-top">
                <div class="team-chip">
                  {card.flag && <img src={card.flag} alt={card.teamName} class="team-flag" />}
                  <div>
                    <div class="team-name">{card.teamName}</div>
                    <div class="team-meta">{card.code} • Grupo {card.group} • {card.continent}</div>
                  </div>
                </div>
                <div class="badges">
                  <span class="card-rank">#{index + 1}</span>
                  <span class:list={['mini-badge', accentClass(`Pulso ${card.momentum}`)]}>Pulso {card.momentum}</span>
                  <span class:list={['mini-badge', accentClass(`Tono ${card.tone}`)]}>Tono {card.tone}</span>
                  <span class:list={['mini-badge', accentClass(card.editorialBadge)]}>{card.editorialBadge}</span>
                </div>
              </div>

              <div class="score-band">
                <div>
                  <strong>{card.trendScore}</strong>
                  <span>score de tendencia</span>
                </div>
                <div>
                  <strong>{card.recentNewsCount}</strong>
                  <span>notas recientes</span>
                </div>
                <div>
                  <strong>{card.newsCount}</strong>
                  <span>notas totales</span>
                </div>
              </div>

              <div class="trend-strip-wrap">
                <span class="trend-arrow">{card.trendDirection}</span>
                <TrendMiniChart points={card.trendLine} compact color="var(--accent-blue)" />
              </div>

              <h2 class="headline">{card.latestHeadline}</h2>
              <p class="analysis">{card.analysis}</p>

              <div class="themes">
                {card.themes.map((theme) => (
                  <span class:list={['theme-tag', accentClass(theme)]}>{theme}</span>
                ))}
              </div>

              <div class="insights-grid">
                <div class="insight-box">
                  <small>Fortalezas</small>
                  <ul>
                    {(card.strengths.length > 0 ? card.strengths : ['lectura general estable']).map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
                <div class="insight-box">
                  <small>Riesgos</small>
                  <ul>
                    {(card.risks.length > 0 ? card.risks : ['sin alertas mediáticas dominantes']).map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
              </div>

              <div class="stats-row">
                <div>
                  <strong>Corte principal:</strong>
                  <span> {formatRelative(card.latestPublished)}</span>
                </div>
                <time datetime={card.latestPublished}>{formatRelative(card.latestPublished)}</time>
              </div>

              <div class="subsection-title">Notas que alimentan el análisis</div>
              <div class="headline-list">
                {card.headlines.map((item) => (
                  <a href={item.id ? `/noticia/${item.id}` : item.url} target={item.id ? '_self' : '_blank'} rel="noopener noreferrer" class="headline-item">
                    <span>{item.title}</span>
                    <small>{item.source} • {formatRelative(item.published)}</small>
                  </a>
                ))}
              </div>

              <div class="card-actions">
                <a href={`/analista/${card.teamId}`} class="btn btn-primary">Ver análisis</a>
                <a href={`/equipo/${card.teamId}`} class="btn btn-ghost">Ver selección</a>
              </div>
            </article>
          ))}
        </div>
      </>
    ) : (
      <div class="empty-state">
        No hay suficiente información reciente para generar tarjetas de análisis todavía.
      </div>
    )}
  </main>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const grid = document.getElementById('analystGrid');
      if (!grid) return;

      const cards = Array.from(grid.querySelectorAll('.analyst-card'));
      const groupFilter = document.getElementById('groupFilter');
      const continentFilter = document.getElementById('continentFilter');
      const toneFilter = document.getElementById('toneFilter');
      const sortFilter = document.getElementById('sortFilter');
      const resultsCounter = document.getElementById('resultsCounter');
      const compareLeft = document.getElementById('compareLeft');
      const compareRight = document.getElementById('compareRight');
      const customCompareResult = document.getElementById('customCompareResult');
      const compareCards = customCompareResult?.dataset.cards ? JSON.parse(customCompareResult.dataset.cards) : [];

      const sortCards = (items, mode) => {
        const sorted = [...items];
        sorted.sort((a, b) => {
          if (mode === 'recent') return Number(b.dataset.recent) - Number(a.dataset.recent);
          if (mode === 'volume') return Number(b.dataset.volume) - Number(a.dataset.volume);
          if (mode === 'name') return String(a.dataset.name).localeCompare(String(b.dataset.name));
          return Number(b.dataset.trend) - Number(a.dataset.trend);
        });
        sorted.forEach((card) => grid.appendChild(card));
      };

      const renderComparison = () => {
        if (!customCompareResult || !compareLeft || !compareRight) return;
        const left = compareCards.find((item) => item.teamId === compareLeft.value);
        const right = compareCards.find((item) => item.teamId === compareRight.value);
        if (!left || !right) return;
        const lead = Math.abs(Number(left.trendScore) - Number(right.trendScore));
        const stronger = Number(left.trendScore) >= Number(right.trendScore) ? left.teamName : right.teamName;
        customCompareResult.innerHTML = `
          <strong>${left.teamName} vs ${right.teamName}</strong>
          <p>${stronger} llega con mejor score reciente. La diferencia es de ${lead} puntos y el duelo enfrenta ${left.editorialBadge.toLowerCase()} contra ${right.editorialBadge.toLowerCase()}.</p>
          <small>${left.teamName}: ${left.strengths?.[0] || 'sin ventaja dominante'} • ${right.teamName}: ${right.strengths?.[0] || 'sin ventaja dominante'} • Temas: ${(left.themes?.[0] || 'Panorama')} vs ${(right.themes?.[0] || 'Panorama')}</small>
        `;
      };

      const applyFilters = () => {
        const group = groupFilter && 'value' in groupFilter ? groupFilter.value : '';
        const continent = continentFilter && 'value' in continentFilter ? continentFilter.value : '';
        const tone = toneFilter && 'value' in toneFilter ? toneFilter.value : '';
        const sort = sortFilter && 'value' in sortFilter ? sortFilter.value : 'trend';

        let visible = 0;
        cards.forEach((card) => {
          const matches = (!group || card.dataset.group === group)
            && (!continent || card.dataset.continent === continent)
            && (!tone || card.dataset.tone === tone);
          card.style.display = matches ? '' : 'none';
          if (matches) visible++;
        });

        sortCards(cards, sort);
        if (resultsCounter) resultsCounter.textContent = `${visible} selecciones`;
      };

      [groupFilter, continentFilter, toneFilter, sortFilter].forEach((el) => {
        el?.addEventListener('change', applyFilters);
      });
      [compareLeft, compareRight].forEach((el) => {
        el?.addEventListener('change', renderComparison);
      });

      applyFilters();
      renderComparison();
    });
  </script>
</Layout>

<style>
