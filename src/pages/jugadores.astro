---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Static page — player data doesn't change at runtime
export const prerender = true;

const allPlayers = await getCollection('players');
const allTeams = await getCollection('teams');

// Team lookup map
const teamMap = Object.fromEntries(
  allTeams
    .filter(t => t.data.qualified)
    .map(t => [t.data.id, { name: t.data.name, flag: t.data.flag, group: t.data.group, code: t.data.code }])
);

// Group players by team
const grouped: Record<string, typeof allPlayers> = {};
for (const player of allPlayers) {
  const tid = player.data.team;
  if (!grouped[tid]) grouped[tid] = [];
  grouped[tid].push(player);
}

// Sort players within each team by shirt number
for (const tid of Object.keys(grouped)) {
  grouped[tid].sort((a, b) => (a.data.number ?? 99) - (b.data.number ?? 99));
}

// Sort teams by group (A→L) then by name
const sortedTeamIds = Object.keys(grouped).sort((a, b) => {
  const ga = teamMap[a]?.group ?? 'Z';
  const gb = teamMap[b]?.group ?? 'Z';
  if (ga !== gb) return ga.localeCompare(gb);
  return (teamMap[a]?.name ?? a).localeCompare(teamMap[b]?.name ?? b);
});

const totalPlayers = allPlayers.length;
const totalTeams = sortedTeamIds.length;

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://futbolexperto.com/' },
        { '@type': 'ListItem', position: 2, name: 'Jugadores', item: 'https://futbolexperto.com/jugadores' },
      ],
    },
    {
      '@type': 'CollectionPage',
      name: 'Jugadores del Mundial 2026',
      url: 'https://futbolexperto.com/jugadores',
      description: `Perfiles y fichas de los ${totalPlayers} jugadores de las ${totalTeams} selecciones clasificadas al Mundial 2026.`,
      inLanguage: 'es',
    },
  ],
};
---

<Layout
  title="Jugadores del Mundial 2026 - FutbolExperto"
  description={`Perfiles y fichas de los ${totalPlayers} jugadores de las ${totalTeams} selecciones clasificadas al Mundial 2026.`}
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
  </Fragment>

  <main class="container section">
    <div class="page-header">
      <h1>Jugadores del Mundial 2026</h1>
      <p class="page-desc">{totalPlayers} jugadores · {totalTeams} selecciones</p>
    </div>

    <!-- Quick-jump by group -->
    <nav class="group-nav" aria-label="Saltar a grupo">
      {['A','B','C','D','E','F','G','H','I','J','K','L'].map(g => (
        <a href={`#grupo-${g}`} class="group-pill">Grupo {g}</a>
      ))}
    </nav>

    {(() => {
      // Render teams grouped by World Cup group
      const groups = ['A','B','C','D','E','F','G','H','I','J','K','L'];
      return groups.map(groupLetter => {
        const teamsInGroup = sortedTeamIds.filter(tid => teamMap[tid]?.group === groupLetter);
        if (teamsInGroup.length === 0) return null;
        return (
          <section class="wc-group" id={`grupo-${groupLetter}`}>
            <h2 class="group-heading">Grupo {groupLetter}</h2>
            {teamsInGroup.map(teamId => {
              const team = teamMap[teamId];
              const players = grouped[teamId] ?? [];
              return (
                <div class="team-block">
                  <div class="team-header">
                    {team?.flag && (
                      <img
                        src={team.flag}
                        alt={team?.name ?? teamId}
                        class="team-flag"
                        width="32"
                        height="24"
                        loading="lazy"
                      />
                    )}
                    <span class="team-name">{team?.name ?? teamId}</span>
                    <span class="team-code">{team?.code ?? ''}</span>
                    <span class="team-count">{players.length} jug.</span>
                  </div>
                  <div class="players-row">
                    {players.map(player => (
                      <a
                        href={`/jugador/${player.data.id}`}
                        class="player-chip"
                        title={`${player.data.name} · ${player.data.position}`}
                      >
                        <span class="chip-number">#{player.data.number ?? '—'}</span>
                        <span class="chip-name">{player.data.name}</span>
                        <span class="chip-pos">{player.data.position?.charAt(0) ?? '?'}</span>
                      </a>
                    ))}
                  </div>
                </div>
              );
            })}
          </section>
        );
      });
    })()}
  </main>
</Layout>

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 { font-size: 2rem; margin-bottom: 0.25rem; }
  .page-desc { color: #555; font-size: 0.9rem; }

  /* Group quick-nav */
  .group-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 2rem;
  }
  .group-pill {
    padding: 0.3rem 0.7rem;
    border: 2px solid #000;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    text-decoration: none;
    color: #000;
    background: #fff;
    transition: background 0.1s;
  }
  .group-pill:hover { background: #000; color: #fff; }

  /* WC Group section */
  .wc-group { margin-bottom: 2.5rem; }
  .group-heading {
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #999;
    border-bottom: 2px solid #000;
    padding-bottom: 0.3rem;
    margin-bottom: 1rem;
  }

  /* Team block */
  .team-block { margin-bottom: 1.25rem; }
  .team-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .team-flag {
    width: 28px;
    height: auto;
    border: 1px solid #ddd;
    object-fit: cover;
    flex-shrink: 0;
  }
  .team-name {
    font-weight: 900;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .team-code {
    font-size: 0.68rem;
    font-weight: 700;
    color: #999;
    padding: 0.1rem 0.35rem;
    border: 1px solid #ddd;
  }
  .team-count {
    margin-left: auto;
    font-size: 0.68rem;
    color: #aaa;
    font-weight: 700;
  }

  /* Player chips */
  .players-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .player-chip {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.55rem;
    border: 1.5px solid #000;
    text-decoration: none;
    color: #000;
    background: #fff;
    font-size: 0.75rem;
    transition: background 0.1s, color 0.1s;
  }
  .player-chip:hover { background: #000; color: #fff; }
  .chip-number {
    font-size: 0.62rem;
    font-weight: 700;
    color: #999;
    min-width: 1.5rem;
  }
  .player-chip:hover .chip-number { color: #aaa; }
  .chip-name { font-weight: 700; }
  .chip-pos {
    font-size: 0.6rem;
    font-weight: 900;
    padding: 0.1rem 0.25rem;
    background: #f0f0f0;
    color: #555;
  }
  .player-chip:hover .chip-pos { background: #333; color: #fff; }

  @media (max-width: 600px) {
    .player-chip { font-size: 0.7rem; }
  }
</style>
