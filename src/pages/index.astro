---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getLatestNews } from '../lib/pocketbase';
import SubscribeForm from '../components/SubscribeForm.astro';

const allTeams = await getCollection('teams');
const teams = allTeams.sort((a, b) => a.data.name.localeCompare(b.data.name));

const groupedByGroup = teams.reduce((acc, team) => {
  const groupName = team.data.group ? `Grupo ${team.data.group}` : 'Por Definir';
  if (!acc[groupName]) acc[groupName] = [];
  acc[groupName].push(team);
  return acc;
}, {} as Record<string, typeof teams>);

const sortedGroups = Object.entries(groupedByGroup).sort(([a], [b]) => {
  if (a === 'Por Definir') return 1;
  if (b === 'Por Definir') return -1;
  return a.localeCompare(b);
});

let latestNews: any[] = [];
try {
  latestNews = await getLatestNews(6);
} catch (e) {
  console.error('Could not fetch news from PocketBase:', e);
}

const formatDate = (dateString: string) => {
  try {
    return new Intl.DateTimeFormat('es-MX', { day: '2-digit', month: 'short' }).format(new Date(dateString));
  } catch { return ''; }
};
---

<Layout title="FutbolXP - Cobertura Total del Mundial 2026">
  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-badge">MUNDIAL 2026</div>
        <h1 class="hero-title">Cobertura Total<br />del <span class="gradient-text">Mundial 2026</span></h1>
        <p class="hero-subtitle">México, USA y Canadá &bull; 48 Equipos &bull; Noticias actualizadas cada 3 horas</p>
        <div class="hero-actions">
          <a href="/noticias" class="btn btn-primary">Ver Noticias</a>
          <a href="#equipos" class="btn btn-ghost">Explorar Equipos</a>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <div class="stat-value">{teams.length}</div>
            <div class="stat-label">Equipos</div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <div class="stat-value">16</div>
            <div class="stat-label">Ciudades</div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <div class="stat-value">3</div>
            <div class="stat-label">Países Sede</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Subscription Form -->
    <SubscribeForm teams={teams} />

    <!-- Latest News from PocketBase -->
    {latestNews.length > 0 && (
      <section class="container section">
        <h2 class="section-title">
          <span class="pulse"></span> Últimas Noticias
        </h2>
        <div class="news-grid">
          {latestNews.map((item: any) => (
            <div class="news-card">
              <div class="title">{item.title}</div>
              {item.contentSnippet && (
                <div class="summary">{item.contentSnippet.slice(0, 100)}...</div>
              )}
              <div class="meta">
                <span class="source">{item.source}</span>
                <span>{item.teamName || item.teamId}</span>
                <span>{formatDate(item.published)}</span>
              </div>
              <a href={item.id ? `/noticia/${item.id}` : item.url} target={item.id ? "_self" : "_blank"} rel="noopener noreferrer" class="read-more-link">Visitar nota &rarr;</a>
            </div>
          ))}
        </div>
        <div style="text-align: center; margin-top: 1.5rem;">
          <a href="/noticias" class="btn btn-ghost">Ver todas las noticias &rarr;</a>
        </div>
      </section>
    )}

    <!-- Teams -->
    <section id="equipos" class="container section">
      <h2 class="section-title">Equipos por Grupo</h2>
      <div class="group-tabs" id="groupTabs">
        <button class="group-tab active" data-group="all">
          Todos
          <span class="tab-count">{teams.filter(t => t.data.qualified).length}</span>
        </button>
        {sortedGroups.map(([groupName]) => (
          <button class="group-tab" data-group={groupName}>
            {groupName}
            <span class="tab-count">{groupedByGroup[groupName].length}</span>
          </button>
        ))}
      </div>

      <div id="groupPanels">
        {sortedGroups.map(([groupName, groupTeams]) => (
          <div class="group-panel" data-panel={groupName}>
            <h3 class="group-header">{groupName}
              {groupName !== 'Por Definir' && (
                <span class="group-note">
                  {(groupTeams as typeof teams).length < 4 ? `• ${4 - (groupTeams as typeof teams).length} lugar(es) por playoff` : '• Grupo completo'}
                </span>
              )}
            </h3>
            <div class="teams-grid">
              {(groupTeams as typeof teams).map((team) => (
                <a href={`/equipo/${team.data.id}`} class="team-card card">
                  <div class="team-card-header">
                    <img src={team.data.flag} alt={team.data.name} class="team-flag" loading="lazy" />
                    <div class="team-info">
                      <h4 class="team-name">{team.data.name}</h4>
                      <div class="team-meta">
                        <span class="team-code">{team.data.code}</span>
                      </div>
                    </div>
                    {team.data.qualified ? (
                      <span class="badge badge-success">Clasificado</span>
                    ) : (
                      <span class="badge badge-warning">En proceso</span>
                    )}
                  </div>
                </a>
              ))}
              {groupName !== 'Por Definir' && (groupTeams as typeof teams).length < 4 && (
                <div class="team-card card playoff-placeholder">
                  <div class="team-card-header">
                    <div class="team-flag playoff-icon">?</div>
                    <div class="team-info">
                      <h4 class="team-name" style="color: var(--color-text-muted);">Por definir en playoffs</h4>
                      <div class="team-meta">
                        <span>Marzo 2026</span>
                      </div>
                    </div>
                    <span class="badge badge-primary">Playoff</span>
                  </div>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll<HTMLButtonElement>('.group-tab');
      const panels = document.querySelectorAll<HTMLElement>('.group-panel');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          // Update active tab
          tabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');

          const group = tab.dataset.group;

          if (group === 'all') {
            panels.forEach(p => p.style.display = '');
          } else {
            panels.forEach(p => {
              p.style.display = p.dataset.panel === group ? '' : 'none';
            });
          }
        });
      });
    });
  </script>
</Layout>

<style>
  .hero {
    position: relative;
    padding: 5rem 0 3rem;
    border-bottom: 3px solid #000000;
  }
  .hero-inner { text-align: center; position: relative; }
  .hero-badge {
    display: inline-block;
    padding: 0.3rem 1rem;
    background: transparent;
    border: 2px solid #000000;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    color: #000000;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
  }
  .hero-title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    margin-bottom: 1rem;
    line-height: 1.05;
    color: #000000;
  }
  .gradient-text {
    color: #000000;
    text-decoration: underline;
    text-decoration-thickness: 4px;
    text-underline-offset: 6px;
  }
  .hero-subtitle {
    font-size: 1.1rem;
    color: #333333;
    margin-bottom: 2rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 3rem;
  }
  .hero-stats {
    display: inline-flex;
    align-items: center;
    gap: 2rem;
    padding: 1rem 2rem;
    background: #ffffff;
    border: 3px solid #000000;
  }
  .stat { text-align: center; }
  .stat-value {
    font-family: 'Google Sans Flex Text', sans-serif;
    font-size: 2rem;
    font-weight: 900;
  }
  .stat-label {
    font-size: 0.7rem;
    color: #666666;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }
  .stat-divider { width: 3px; height: 36px; background: #000000; }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 0.75rem;
  }

  /* ===== GROUP TABS ===== */
  .group-tabs {
    display: flex;
    gap: 0.35rem;
    overflow-x: auto;
    padding-bottom: 0.75rem;
    margin-bottom: 2rem;
    scrollbar-width: none;
    position: sticky;
    top: 67px;
    z-index: 50;
    background: #ffffff;
    padding-top: 0.75rem;
  }
  .group-tabs::-webkit-scrollbar { display: none; }

  .group-tab {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.8rem;
    background: #ffffff;
    border: 2px solid #000000;
    color: #000000;
    font-size: 0.75rem;
    font-weight: 700;
    white-space: nowrap;
    cursor: pointer;
    transition: all 0.1s;
    font-family: 'Google Sans Flex Text', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .group-tab:hover {
    transform: translate(-2px, -2px);
    box-shadow: 2px 2px 0px #000000;
  }
  .group-tab.active {
    background: #000000;
    color: #ffffff;
  }
  .group-tab.active .tab-count {
    background: rgba(255,255,255,0.3);
    color: #ffffff;
  }
  .tab-count {
    font-size: 0.6rem;
    background: #f0f0f0;
    padding: 0.1rem 0.35rem;
    color: #333333;
    font-weight: 800;
    border: 1px solid #000000;
  }

  /* ===== GROUP PANELS ===== */
  .group-panel {
    margin-bottom: 2.5rem;
  }
  .group-header {
    font-size: 1.1rem;
    color: #000000;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 3px solid #000000;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .group-note {
    font-size: 0.75rem;
    font-weight: 500;
    color: #666666;
    text-transform: none;
  }

  .teams-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.6rem;
  }
  .team-card { display: block; text-decoration: none; color: inherit; }
  .team-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
  }
  .team-flag {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    object-fit: cover;
    background: #f5f5f5;
    flex-shrink: 0;
    border: 2px solid #000000;
  }
  .playoff-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 900;
    color: #666666;
    border: 2px dashed #000000;
    border-radius: 50%;
  }
  .playoff-placeholder {
    border-style: dashed;
    opacity: 0.5;
  }
  .playoff-placeholder:hover {
    transform: none;
    box-shadow: none;
  }
  .team-info { flex: 1; min-width: 0; }
  .team-name {
    font-family: 'Google Sans Flex Text', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
  }
  .team-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: #666666;
  }
  .team-code { font-weight: 700; color: #333333; text-transform: uppercase; }

  @media (max-width: 768px) {
    .hero { padding: 3rem 0 2rem; }
    .hero-stats { gap: 1.5rem; padding: 0.75rem 1.5rem; }
    .stat-divider { display: none; }
    .teams-grid, .news-grid { grid-template-columns: 1fr; }
    .hero-actions { flex-direction: column; align-items: center; }
    .group-tabs { top: 67px; }
  }
</style>
