---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getLatestNews } from '../lib/pocketbase';
import { buildAnalystCards, buildAnalystEditorialSummary, buildAnalystForecastBoards, buildAnalystTiers } from '../lib/analyst';
import TrendMiniChart from '../components/TrendMiniChart.astro';
import SubscribeForm from '../components/SubscribeForm.astro';

const allTeams = await getCollection('teams');
const teams = allTeams.sort((a, b) => a.data.name.localeCompare(b.data.name));

const groupedByGroup = teams.reduce((acc, team) => {
  const groupName = team.data.group ? `Grupo ${team.data.group}` : 'Por Definir';
  if (!acc[groupName]) acc[groupName] = [];
  acc[groupName].push(team);
  return acc;
}, {} as Record<string, typeof teams>);

const sortedGroups = Object.entries(groupedByGroup).sort(([a], [b]) => {
  if (a === 'Por Definir') return 1;
  if (b === 'Por Definir') return -1;
  return a.localeCompare(b);
});

let latestNews: any[] = [];
try {
  latestNews = await getLatestNews(24);
} catch (e) {
  console.error('Could not fetch news from PocketBase:', e);
}

const allAnalystCards = buildAnalystCards(allTeams, latestNews, 40).filter((card) => card.qualified);
const analystCards = allAnalystCards.slice(0, 3);
const analystTiers = buildAnalystTiers(allAnalystCards).slice(0, 2);
const forecastBoards = buildAnalystForecastBoards(allAnalystCards).slice(0, 1);
const analystSummary = buildAnalystEditorialSummary(allAnalystCards);

const accentClass = (value: string) => {
  const normalized = value.toLowerCase();
  if (normalized.includes('ataque') || normalized.includes('figura')) return 'accent-violet';
  if (normalized.includes('defensa') || normalized.includes('pulso')) return 'accent-blue';
  if (normalized.includes('lesiones') || normalized.includes('alerta')) return 'accent-rose';
  return 'accent-green';
};

const formatDate = (dateString: string) => {
  try {
    return new Intl.DateTimeFormat('es-MX', { day: '2-digit', month: 'short' }).format(new Date(dateString));
  } catch { return ''; }
};
---

<Layout title="FutbolExperto - Cobertura Total del Mundial 2026">
  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-badge">MUNDIAL 2026</div>
        <h1 class="hero-title">Cobertura Total<br />del <span class="gradient-text">Mundial 2026</span></h1>
        <p class="hero-subtitle">México, USA y Canadá &bull; 48 Equipos &bull; ¡Lo último del camino al 2026!</p>
        <div class="hero-actions">
          <a href="/noticias" class="btn btn-primary">Ver Noticias</a>
          <a href="#equipos" class="btn btn-ghost">Explorar Equipos</a>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <div class="stat-value">{teams.length}</div>
            <div class="stat-label">Equipos</div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <div class="stat-value">16</div>
            <div class="stat-label">Ciudades</div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <div class="stat-value">3</div>
            <div class="stat-label">Países Sede</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Latest News from PocketBase -->
    {latestNews.length > 0 && (
      <section class="container section deferred-section">
        <h2 class="section-title">
          <span class="pulse"></span> Últimas Noticias
        </h2>
        <div class="news-grid">
          {latestNews.slice(0, 6).map((item: any) => (
            <div class="news-card">
              <div class="title">{item.title}</div>
              {item.contentSnippet && (
                <div class="summary">{item.contentSnippet.slice(0, 100)}...</div>
              )}
              <div class="meta">
                <span class="source">{item.source}</span>
                <span>{item.teamName || item.teamId}</span>
                <span>{formatDate(item.published)}</span>
              </div>
              <a href={item.id ? `/noticia/${item.id}` : item.url} target={item.id ? "_self" : "_blank"} rel="noopener noreferrer" class="read-more-link">Visitar nota &rarr;</a>
            </div>
          ))}
        </div>
        <div style="text-align: center; margin-top: 1.5rem;">
          <a href="/noticias" class="btn btn-ghost">Ver todas las noticias &rarr;</a>
        </div>
      </section>
    )}

    {analystCards.length > 0 && (
      <section class="container section analyst-preview-section deferred-section">
        <div class="analyst-home-head">
          <h2 class="section-title">Analista</h2>
          <div class="analyst-home-actions">
            <a href="/analista" class="btn btn-primary">Ir a Analista &rarr;</a>
            <a href="/analista/comparar" class="btn btn-ghost">Comparar selecciones</a>
          </div>
        </div>

        {analystSummary && (
          <article class="home-summary-card card">
            <div class="forecast-kicker accent-blue">Resumen del día</div>
            <h3>{analystSummary.headline}</h3>
            <p>{analystSummary.summary}</p>
            <div class="home-summary-list">
              {analystSummary.highlights.map((item) => (
                <span class="home-summary-item">{item}</span>
              ))}
            </div>
          </article>
        )}

        <div class="analyst-preview-grid">
          {analystCards.map((card) => (
            <article class="analyst-preview-card card">
              <div class="analyst-preview-top">
                <div class="analyst-team">
                  {card.flag && <img src={card.flag} alt={card.teamName} class="team-flag" loading="lazy" />}
                  <div>
                    <h3>{card.teamName}</h3>
                    <p>{card.code} • {card.group ? `Grupo ${card.group}` : 'Por definir'}</p>
                  </div>
                </div>
                <span class:list={['badge', accentClass(`Pulso ${card.momentum}`)]}>Pulso {card.momentum}</span>
              </div>
              <div class="analyst-preview-headline">{card.latestHeadline}</div>
              <p class="analyst-preview-text">{card.analysis}</p>
              <div class="analyst-preview-tags">
                {card.themes.map((theme) => (
                  <span class:list={['tab-count', accentClass(theme)]}>{theme}</span>
                ))}
              </div>
              <TrendMiniChart points={card.trendLine} compact color="var(--accent-blue)" />
              <div class="analyst-preview-actions">
                <a href={`/analista/${card.teamId}`} class="read-more-link">Ver análisis &rarr;</a>
              </div>
            </article>
          ))}
        </div>

        <div class="home-insight-grid">
          {forecastBoards.map((board) => (
            <article class:list={['home-forecast-card', 'card', accentClass(board.title)]}>
              <div class="forecast-kicker">Predicción editorial</div>
              <h3>{board.title}</h3>
              <div class="home-forecast-list compact-list">
                {board.teams.slice(0, 3).map((team, index) => (
                  <a href={`/analista/${team.teamId}`} class="home-forecast-item">
                    <span>#{index + 1} {team.teamName}</span>
                    <small>{team.trendScore} pts • {team.editorialBadge}</small>
                  </a>
                ))}
              </div>
            </article>
          ))}

          {analystTiers.map((tier) => (
            <article class="home-tier-card card">
              <div class:list={['forecast-kicker', accentClass(tier.title)]}>Panel del día</div>
              <h3>{tier.title}</h3>
              <div class="home-tier-list compact-list">
                {tier.teams.slice(0, 3).map((team) => (
                  <a href={`/analista/${team.teamId}`} class="home-tier-item">
                    <span>{team.teamName}</span>
                    <small>{team.trendDirection} {team.trendScore} pts</small>
                  </a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Teams -->
    <section id="equipos" class="container section deferred-section">
      <h2 class="section-title">Equipos por Grupo</h2>
      <div class="group-tabs" id="groupTabs">
        <button class="group-tab active" data-group="all">
          Todos
          <span class="tab-count">{teams.filter(t => t.data.qualified).length}</span>
        </button>
        {sortedGroups.map(([groupName]) => (
          <button class="group-tab" data-group={groupName}>
            {groupName}
            <span class="tab-count">{groupedByGroup[groupName].length}</span>
          </button>
        ))}
      </div>

      <div id="groupPanels">
        {sortedGroups.map(([groupName, groupTeams]) => (
          <div class="group-panel" data-panel={groupName}>
            <h3 class="group-header">{groupName}
              {groupName !== 'Por Definir' && (
                <span class="group-note">
                  {(groupTeams as typeof teams).length < 4 ? `• ${4 - (groupTeams as typeof teams).length} lugar(es) por playoff` : '• Grupo completo'}
                </span>
              )}
            </h3>
            <div class="teams-grid">
              {(groupTeams as typeof teams).map((team) => (
                <a href={`/equipo/${team.data.id}`} class="team-card card">
                  <div class="team-card-header">
                    <img src={team.data.flag} alt={team.data.name} class="team-flag" loading="lazy" />
                    <div class="team-info">
                      <h4 class="team-name">{team.data.name}</h4>
                      <div class="team-meta">
                        <span class="team-code">{team.data.code}</span>
                      </div>
                    </div>
                    {team.data.qualified ? (
                      <span class="badge badge-success">Clasificado</span>
                    ) : (
                      <span class="badge badge-warning">En proceso</span>
                    )}
                  </div>
                </a>
              ))}
              {groupName !== 'Por Definir' && (groupTeams as typeof teams).length < 4 && (
                <div class="team-card card playoff-placeholder">
                  <div class="team-card-header">
                    <div class="team-flag playoff-icon">?</div>
                    <div class="team-info">
                      <h4 class="team-name" style="color: var(--color-text-muted);">Por definir en playoffs</h4>
                      <div class="team-meta">
                        <span>Marzo 2026</span>
                      </div>
                    </div>
                    <span class="badge badge-primary">Playoff</span>
                  </div>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Subscription Form -->
    <SubscribeForm teams={teams} />
  </main>

  <script is:inline>
    document.addEventListener('click', (e) => {
      const link = e.target.closest('.read-more-link');
      if (link && link.getAttribute('target') !== '_blank') {
        const title = link.closest('.news-card')?.querySelector('.title')?.textContent;
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          'event': 'content_interaction',
          'interaction_type': 'internal_news_view',
          'content_title': title
        });
      }
    });

    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('.group-tab');
      const panels = document.querySelectorAll('.group-panel');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          // Update active tab
          tabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');

          const group = tab.dataset.group;

          // GTM Event
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            'event': 'news_category_filter',
            'filter_type': 'group_tab',
            'filter_value': group
          });

          if (group === 'all') {
            panels.forEach(p => p.style.display = '');
          } else {
            panels.forEach(p => {
              p.style.display = p.dataset.panel === group ? '' : 'none';
            });
          }
        });
      });
    });
  </script>
</Layout>

<style>
  .hero {
    position: relative;
    padding: 5rem 0 3rem;
    border-bottom: 3px solid #000000;
  }
  .hero-inner { text-align: center; position: relative; }
  .hero-badge {
    display: inline-block;
    padding: 0.3rem 1rem;
    background: transparent;
    border: 2px solid #000000;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    color: #000000;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
  }
  .hero-title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    margin-bottom: 1rem;
    line-height: 1.05;
    color: #000000;
  }
  .gradient-text {
    color: #000000;
    text-decoration: underline;
    text-decoration-thickness: 4px;
    text-underline-offset: 6px;
  }
  .hero-subtitle {
    font-size: 1.1rem;
    color: #333333;
    margin-bottom: 2rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 3rem;
  }
  .hero-stats {
    display: inline-flex;
    align-items: center;
    gap: 2rem;
    padding: 1rem 2rem;
    background: #ffffff;
    border: 3px solid #000000;
  }
  .stat { text-align: center; }
  .stat-value {
    font-family: 'Google Sans Flex Text', sans-serif;
    font-size: 2rem;
    font-weight: 900;
  }
  .stat-label {
    font-size: 0.7rem;
    color: #666666;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }
  .stat-divider { width: 3px; height: 36px; background: #000000; }

  .deferred-section {
    content-visibility: auto;
    contain-intrinsic-size: 1px 1200px;
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 0.75rem;
  }

  /* ===== GROUP TABS ===== */
  .group-tabs {
    display: flex;
    gap: 0.35rem;
    overflow-x: auto;
    padding-bottom: 0.75rem;
    margin-bottom: 2rem;
    scrollbar-width: none;
    position: sticky;
    top: 67px;
    z-index: 50;
    background: #ffffff;
    padding-top: 0.75rem;
  }
  .group-tabs::-webkit-scrollbar { display: none; }

  .group-tab {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.8rem;
    background: #ffffff;
    border: 2px solid #000000;
    color: #000000;
    font-size: 0.75rem;
    font-weight: 700;
    white-space: nowrap;
    cursor: pointer;
    transition: all 0.1s;
    font-family: 'Google Sans Flex Text', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .group-tab:hover {
    transform: translate(-3px, -3px);
    text-decoration: underline;
    text-decoration-thickness: 2px;
  }
  .group-tab.active {
    background: #ffffff;
    color: #000000;
    border-width: 4px;
    text-decoration: underline;
    text-decoration-thickness: 3px;
    text-underline-offset: 4px;
  }
  .group-tab.active .tab-count {
    background: #ffffff;
    color: #000000;
  }
  .tab-count {
    font-size: 0.6rem;
    background: #f0f0f0;
    padding: 0.1rem 0.35rem;
    color: #333333;
    font-weight: 800;
    border: 1px solid #000000;
  }

  /* ===== GROUP PANELS ===== */
  .group-panel {
    margin-bottom: 2.5rem;
  }
  .group-header {
    font-size: 1.1rem;
    color: #000000;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 3px solid #000000;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .group-note {
    font-size: 0.75rem;
    font-weight: 500;
    color: #666666;
    text-transform: none;
  }

  .analyst-home-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
  }
  .analyst-home-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .analyst-preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .analyst-preview-card {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    background: #ffffff;
    border-color: var(--accent-blue);
    box-shadow: 6px 6px 0 var(--accent-blue-soft);
  }
  .analyst-preview-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .analyst-team {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    min-width: 0;
    flex: 1 1 auto;
  }
  .analyst-team h3 {
    font-size: 0.95rem;
    line-height: 1.2;
  }
  .analyst-team p {
    font-size: 0.72rem;
    color: #666666;
    font-weight: 700;
    text-transform: uppercase;
  }
  .analyst-preview-headline {
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .analyst-preview-text {
    color: #333333;
    font-size: 0.88rem;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .analyst-preview-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .analyst-preview-actions {
    margin-top: auto;
  }
  .home-summary-card {
    padding: 1rem;
    margin-bottom: 1rem;
    border-color: var(--accent-blue);
    box-shadow: 6px 6px 0 var(--accent-blue-soft);
  }
  .home-summary-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.35rem;
  }
  .home-summary-card p {
    font-size: 0.92rem;
    color: #333333;
    margin-bottom: 0.75rem;
  }
  .home-summary-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .home-summary-item {
    display: inline-flex;
    border: 2px solid #000000;
    padding: 0.35rem 0.6rem;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    background: #ffffff;
  }
  .home-insight-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .home-forecast-card,
  .home-tier-card {
    padding: 1rem;
  }
  .compact-list {
    gap: 0.35rem;
  }
  .forecast-kicker {
    display: inline-block;
    padding: 0.2rem 0.5rem;
    border: 2px solid #000000;
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .home-forecast-card h3,
  .home-tier-card h3 {
    font-size: 1rem;
    margin-bottom: 0.35rem;
  }
  .home-forecast-card p {
    font-size: 0.88rem;
    color: #333333;
    margin-bottom: 0.75rem;
  }
  .home-forecast-list,
  .home-tier-list {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .home-forecast-item,
  .home-tier-item {
    border: 2px solid #000000;
    padding: 0.7rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    background: #ffffff;
  }
  .home-forecast-item span,
  .home-tier-item span {
    font-size: 0.9rem;
    font-weight: 800;
    text-transform: uppercase;
  }
  .home-forecast-item small,
  .home-tier-item small {
    font-size: 0.72rem;
    color: #666666;
    text-transform: uppercase;
    font-weight: 800;
  }

  .teams-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.6rem;
  }
  .team-card { display: block; text-decoration: none; color: inherit; }
  .team-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
  }
  .team-flag {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    object-fit: cover;
    background: #f5f5f5;
    flex-shrink: 0;
    border: 2px solid #000000;
  }
  .playoff-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 900;
    color: #666666;
    border: 2px dashed #000000;
    border-radius: 50%;
  }
  .playoff-placeholder {
    border-style: dashed;
    opacity: 0.5;
  }
  .playoff-placeholder:hover {
    transform: none;
    box-shadow: none;
  }
  .team-info { flex: 1; min-width: 0; }
  .team-name {
    font-family: 'Google Sans Flex Text', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
  }
  .team-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: #666666;
  }
  .team-code { font-weight: 700; color: #333333; text-transform: uppercase; }

  @media (max-width: 768px) {
    .hero { padding: 3rem 0 2rem; }
    .hero-stats { gap: 1rem; padding: 0.75rem 1rem; width: 100%; max-width: 360px; justify-content: center; }
    .stat-divider { display: none; }
    .teams-grid, .news-grid, .analyst-preview-grid, .home-insight-grid { grid-template-columns: 1fr; }
    .hero-actions { flex-direction: column; align-items: stretch; width: 100%; max-width: 320px; margin-inline: auto; }
    .analyst-home-head { flex-direction: column; align-items: stretch; }
    .analyst-home-actions { width: 100%; }
    .analyst-preview-top { flex-direction: column; }
    .group-tabs { top: 67px; }
    .group-tab { flex-shrink: 0; }
  }
</style>
