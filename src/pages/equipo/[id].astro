---
import Layout from '../../layouts/Layout.astro';
import { getEntry, getCollection } from 'astro:content';
import { getLatestNews, getNewsByTeam } from '../../lib/pocketbase';
import { buildAnalystCards, buildAnalystComparison } from '../../lib/analyst';
import TrendMiniChart from '../../components/TrendMiniChart.astro';

export const prerender = false;

const { id } = Astro.params;
const entry = await getEntry('teams', id as any);

if (!entry) {
  return Astro.redirect('/404');
}

const team = entry.data;

// Get players for this team
const allPlayers = await getCollection('players');
const allTeams = await getCollection('teams');
const teamPlayers = allPlayers.filter(p => p.data.team === team.id);

// Fetch news from PocketBase
let pbNews: any[] = [];
try {
  pbNews = await getNewsByTeam(team.id, 10);
} catch (e) {
  console.error(`Error fetching PB news for ${team.id}:`, e);
}

// Merge PocketBase news with static news, prefer PocketBase
const staticNews = team.news || [];
const allNewsUrls = new Set(pbNews.map((n: any) => n.url));
const mergedNews: any[] = [
  ...pbNews.map((n: any) => ({ 
    id: n.id, 
    title: n.title, 
    url: n.url, 
    source: n.source, 
    published: n.published, 
    contentSnippet: n.contentSnippet 
  })),
  ...staticNews.filter(n => !allNewsUrls.has(n.url)),
].sort((a, b) => new Date(b.published).getTime() - new Date(a.published).getTime()).slice(0, 10);

let latestNews: any[] = [];
try {
  latestNews = await getLatestNews(220);
} catch (e) {
  console.error('Error fetching latest news for analyst module:', e);
}

const analystCards = buildAnalystCards(allTeams, latestNews, 80).filter((card) => card.qualified);
const analystCard = analystCards.find((card) => card.teamId === team.id);
const analystPeer = analystCard
  ? analystCards.find((card) => card.teamId !== team.id && (card.group === analystCard.group || card.continent === analystCard.continent))
  : null;
const analystComparison = analystCard && analystPeer ? buildAnalystComparison(analystCard, analystPeer) : null;

const accentClass = (value: string) => {
  const normalized = value.toLowerCase();
  if (normalized.includes('fortale') || normalized.includes('ascenso')) return 'accent-green';
  if (normalized.includes('riesgo') || normalized.includes('alerta')) return 'accent-rose';
  if (normalized.includes('trend') || normalized.includes('pts')) return 'accent-blue';
  return 'accent-violet';
};

const formatDate = (dateString: string) => {
  try {
    return new Intl.DateTimeFormat('es-MX', { day: '2-digit', month: 'short', year: 'numeric' }).format(new Date(dateString));
  } catch { return ''; }
};

const teamUrl = `https://futbolexperto.com/equipo/${team.id}`;
const teamSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://futbolexperto.com/' },
        { '@type': 'ListItem', position: 2, name: team.name, item: teamUrl },
      ],
    },
    {
      '@type': 'SportsTeam',
      name: team.name,
      alternateName: team.code,
      url: teamUrl,
      sport: 'Soccer',
      memberOf: {
        '@type': 'SportsOrganization',
        name: 'Futbol 2026',
      },
      nationality: team.continent,
      description: `Perfil, noticias y análisis de ${team.name} en FutbolExperto para Futbol 2026.`,
      image: team.flag ? [team.flag] : undefined,
    },
  ],
};
---

<Layout title={`${team.name} - FutbolExperto`} description={`Noticias, contexto y análisis de ${team.name} para Futbol 2026. Grupo ${team.group || 'por definir'}, ${team.continent}.`}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(teamSchema)} />
  </Fragment>
  <main class="container section">
    <!-- Team Header -->
    <div class="team-header">
      <a href="/" class="back-link">&larr; Todos los equipos</a>
      <div class="team-profile">
        <img src={team.flag} alt={team.name} class="team-flag" />
        <div class="team-details">
          <h1 class="team-title">{team.name}</h1>
          <div class="team-badges">
            <span class="badge badge-primary">{team.code}</span>
            {team.group && <span class="badge badge-primary">Grupo {team.group}</span>}
            <span class="badge badge-primary">{team.continent}</span>
            {team.qualified ? (
              <span class="badge badge-success">Clasificado</span>
            ) : (
              <span class="badge badge-warning">En proceso</span>
            )}
          </div>
        </div>
      </div>
    </div>

    <div class="content-grid">
      <!-- Main: News -->
      <div class="main-col">
        {analystCard && (
          <section class="analyst-module card">
            <div class="analyst-module-head">
              <div>
                <h2 class="section-title" style="margin-bottom: 0.75rem;">Analista</h2>
                <p class="analyst-copy">{analystCard.analysis}</p>
              </div>
              <div class="analyst-badges">
                <span class:list={['badge', accentClass(analystCard.editorialBadge)]}>{analystCard.editorialBadge}</span>
                <span class:list={['badge', accentClass(`${analystCard.trendDirection} ${analystCard.trendScore} pts`)]}>{analystCard.trendDirection} {analystCard.trendScore} pts</span>
              </div>
            </div>

            <div class="analyst-inline-grid">
              <div class="analyst-box">
                <small>Fortalezas</small>
                <ul>
                  {(analystCard.strengths.length > 0 ? analystCard.strengths : ['lectura general estable']).map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
              <div class="analyst-box">
                <small>Riesgos</small>
                <ul>
                  {(analystCard.risks.length > 0 ? analystCard.risks : ['sin alertas dominantes']).map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="analyst-trend-strip">
              <TrendMiniChart points={analystCard.trendLine} title="Pulso reciente" color="var(--accent-blue)" />
            </div>

            {analystComparison && (
              <div class="analyst-compare-inline">
                <strong>Comparativa rápida:</strong> {analystComparison.summary}
              </div>
            )}

            <div class="analyst-actions">
              <a href={`/analista/${team.id}`} class="btn btn-primary">Ver análisis completo</a>
              <a href="/analista" class="btn btn-ghost">Ir al radar</a>
            </div>
          </section>
        )}

        <h2 class="section-title">Noticias</h2>
        {mergedNews.length > 0 ? (
          <div class="news-list">
            {mergedNews.map((item) => (
              <div class="news-card">
                <div class="title">{item.title}</div>
                {item.contentSnippet && (
                  <div class="summary" style="font-size: 0.85rem; color: var(--color-text-secondary); margin-bottom: 0.5rem;">{item.contentSnippet.slice(0, 100)}...</div>
                )}
                <div class="meta" style="margin-bottom: 0.75rem;">
                  <span class="source">{item.source}</span>
                  <time datetime={item.published}>{formatDate(item.published)}</time>
                </div>
                <a href={item.id ? `/noticia/${item.id}` : item.url} target={item.id ? "_self" : "_blank"} rel="noopener noreferrer" class="read-more-link" style="color: #000000; font-weight: 800; font-size: 0.85rem; text-decoration: underline; text-underline-offset: 3px; text-transform: uppercase;">Visitar nota &rarr;</a>
              </div>
            ))}
          </div>
        ) : (
          <div class="empty-state">No hay noticias disponibles para este equipo.</div>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="sidebar">
        <!-- Players -->
        {teamPlayers.length > 0 && (
          <div class="sidebar-section">
            <h3 class="sidebar-title">Jugadores ({teamPlayers.length})</h3>
            <div class="player-list">
              {teamPlayers.map((player) => (
                <a href={`/jugador/${player.data.id}`} class="player-item">
                  <div class="player-avatar">
                    {player.data.photo ? (
                      <img src={player.data.photo} alt={player.data.name} />
                    ) : (
                      <span>{player.data.name.charAt(0)}</span>
                    )}
                  </div>
                  <div class="player-info">
                    <div class="player-name">{player.data.name}</div>
                    <div class="player-pos">{player.data.position} {player.data.number ? `#${player.data.number}` : ''}</div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Social -->
        {team.social && (
          <div class="sidebar-section">
            <h3 class="sidebar-title">Redes Sociales</h3>
            <div class="social-list">
              {team.social.twitter && (
                <a href={team.social.twitter} target="_blank" rel="noopener noreferrer" class="social-btn twitter">Twitter / X</a>
              )}
              {team.social.instagram && (
                <a href={team.social.instagram} target="_blank" rel="noopener noreferrer" class="social-btn instagram">Instagram</a>
              )}
              {team.social.officialSite && (
                <a href={team.social.officialSite} target="_blank" rel="noopener noreferrer" class="social-btn website">Sitio Oficial</a>
              )}
            </div>
          </div>
        )}
      </aside>
    </div>
  </main>
</Layout>

<style>
  .team-header {
    margin-bottom: 2.5rem;
  }
  .back-link {
    display: inline-block;
    color: #000000;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .back-link:hover { text-decoration-thickness: 3px; }
  .team-profile {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem;
    background: #ffffff;
    border: 3px solid #000000;
  }
  .team-flag {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    background: #f5f5f5;
    flex-shrink: 0;
    border: 3px solid #000000;
  }
  .team-title {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    line-height: 1.08;
  }
  .team-badges {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .team-details {
    min-width: 0;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 2rem;
    align-items: start;
  }

  .analyst-module {
    padding: 1.25rem;
    margin-bottom: 1.25rem;
    border-color: var(--accent-blue);
    box-shadow: 8px 8px 0 var(--accent-blue-soft);
  }
  .analyst-module-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1rem;
  }
  .analyst-module-head > div:first-child {
    min-width: 0;
    flex: 1 1 auto;
  }
  .analyst-copy {
    color: #333333;
    font-size: 0.95rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .analyst-badges {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    justify-content: flex-end;
    flex: 0 1 240px;
  }
  .analyst-inline-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.6rem;
    margin-bottom: 0.75rem;
  }
  .analyst-box {
    border: 2px solid var(--accent-violet);
    padding: 0.8rem;
    background: #ffffff;
    box-shadow: 4px 4px 0 var(--accent-violet-soft);
  }
  .analyst-box:last-child {
    border-color: var(--accent-rose);
    box-shadow: 4px 4px 0 var(--accent-rose-soft);
  }
  .analyst-box small,
  .trend-mini-box small {
    display: block;
    font-size: 0.68rem;
    color: #666666;
    text-transform: uppercase;
    font-weight: 800;
    margin-bottom: 0.3rem;
  }
  .analyst-box ul {
    margin-left: 1rem;
    display: grid;
    gap: 0.3rem;
    font-size: 0.88rem;
  }
  .analyst-trend-strip {
    margin-bottom: 0.75rem;
  }
  .analyst-compare-inline {
    border-top: 2px solid #000000;
    padding-top: 0.75rem;
    font-size: 0.88rem;
    color: #333333;
    margin-bottom: 0.85rem;
  }
  .analyst-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .news-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .news-card .title {
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .sidebar-section {
    background: #ffffff;
    border: 2px solid #000000;
    padding: 1.25rem;
  }
  .sidebar-title {
    font-size: 0.85rem;
    color: #000000;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #000000;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .player-list {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .player-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem;
    border: 1px solid transparent;
    transition: all 0.1s;
  }
  .player-item:hover {
    border: 1px solid #000000;
    background: #f5f5f5;
  }
  .player-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #f0f0f0;
    border: 2px solid #000000;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 0.8rem;
    font-weight: 800;
    color: #666666;
  }
  .player-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .player-name { font-size: 0.85rem; font-weight: 700; text-transform: uppercase; }
  .player-pos { font-size: 0.7rem; color: #666666; text-transform: uppercase; font-weight: 600; }

  .social-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .social-btn {
    display: block;
    padding: 0.6rem 1rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    background: #ffffff;
    border: 2px solid #000000;
    color: #000000;
    transition: all 0.1s;
  }
  .social-btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 2px 2px 0px #000000;
  }
  .social-btn.twitter { background: #ffffff; color: #000000; }
  .social-btn.instagram { background: #ffffff; color: #000000; }
  .social-btn.website { background: #ffffff; color: #000000; }

  @media (max-width: 768px) {
    .content-grid, .analyst-inline-grid, .analyst-trend-strip { grid-template-columns: 1fr; }
    .team-title { font-size: 1.5rem; }
    .team-flag { width: 56px; height: 56px; }
    .team-profile { padding: 1.25rem; align-items: flex-start; }
    .back-link { margin-bottom: 1rem; }
    .analyst-module-head { flex-direction: column; }
    .analyst-badges { justify-content: flex-start; }
  }
</style>
