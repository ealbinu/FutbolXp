import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import type { Team } from '../content/config';

export async function getStaticPaths() {
  const teams = await getCollection('teams');
  const sortedTeams = teams.sort((a, b) => a.data.name.localeCompare(b.data.name));
  
  return sortedTeams.map((team) => ({
    params: { id: team.data.id },
    props: { team: team.data },
  }));
}

const { team } = Astro.props;
const isQualified = team.qualified;

// Formatear fecha
const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return new Intl.DateTimeFormat('es-ES', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  }).format(date);
};

// Agrupar noticias por fecha reciente
const recentNews = team.news?.slice(0, 3) || [];
</script>

<Layout title={`${team.name} - Fútbol Experto 2026`}>
  <main class="container section">
    <div class="team-profile" style="max-width: 800px; margin: 0 auto 3rem;">
      <div class="team-header" style="display: flex; align-items: center; gap: 1.5rem; padding: 2rem; background: var(--gradient-card); border-radius: 16px; border: 1px solid var(--color-border);">
        <img 
          src={team.flag} 
          alt={`Bandera de ${team.name}`} 
          class="team-flag" 
          style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover;"
        />
        <div>
          <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">{team.name}</h1>
          <div style="display: flex; gap: 1rem; flex-wrap: wrap; color: var(--color-text-muted); font-size: 0.9rem;">
            <span>🏆 Mundial 2026</span>
            <span>🌍 {team.continent}</span>
            <span>📋 Grupo {team.group || 'Por definir'}</span>
            {isQualified 
              ? <span style="color: #00ff88;">✅ Clasificado</span>
              : <span style="color: var(--color-warning);">⏳ En proceso</span>
            }
          </div>
        </div>
      </div>
    </div>

    <!-- Noticias del Equipo -->
    <section class="team-news" style="margin-bottom: 3rem;">
      <h2 style="font-size: 1.75rem; margin-bottom: 1.5rem; border-bottom: 2px solid var(--color-accent); padding-bottom: 0.5rem;">
        📰 Últimas Noticias de {team.name}
      </h2>
      
      {recentNews.length > 0 ? (
        <div class="news-list">
          {recentNews.map((item) => (
            <article class="news-item">
              <a href={item.url} target="_blank" rel="noopener noreferrer">
                <span class="news-title">{item.title}</span>
              </a>
              <div class="news-meta">
                <span>{item.source}</span>
                <time datetime={item.published}>{formatDate(item.published)}</time>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <p style="color: var(--color-text-muted); text-align: center; padding: 2rem;">
          No hay noticias disponibles para este equipo aún.
        </p>
      )}
      
      {team.news && team.news.length > 3 && (
        <div style="text-align: center; margin-top: 1.5rem;">
          <a href="/equipo/{team.id}/noticias" style="color: var(--color-accent); font-weight: 600;">
            Ver todas las noticias ({team.news.length}) →
          </a>
        </div>
      )}
    </section>

    <!-- Jugadores Destacados -->
    {team.players && team.players.length > 0 && (
      <section class="team-players" style="margin-bottom: 3rem;">
        <h2 style="font-size: 1.75rem; margin-bottom: 1.5rem; border-bottom: 2px solid var(--color-accent); padding-bottom: 0.5rem;">
          ⚽ Jugadores Clave
        </h2>
        <div class="players-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
          <!-- Aquí se mostrarán los jugadores, por ahora un placeholder -->
          {team.players.map((playerSlug) => (
            <div class="player-card" style="padding: 1.5rem; background: var(--gradient-card); border: 1px solid var(--color-border); border-radius: 12px;">
              <div style="display: flex; align-items: center; gap: 1rem;">
                <div style="width: 56px; height: 56px; border-radius: 50%; background: var(--color-surface);"></div>
                <div>
                  <div style="font-weight: 600; font-size: 1rem;">{playerSlug.replace('h-', '').replace('a-', '').replace('b-', '').replace('c-', '').replace('d-', '').replace('e-', '').replace('f-', '').replace('g-', '').replace('i-', '').replace('j-', '').replace('k-', '').replace('l-', '').replace('m-', '').replace('n-', '').replace('p-', '').replace('s-', '').replace('t-', '').replace('u-', '').replace('w-', '').replace('a-', '').replace('e-', '').replace('i-', '').replace('o-', '').replace('u-', '').split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</div>
                  <div style="font-size: 0.85rem; color: var(--color-text-muted);">Jugador de {team.name}</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Enlaces a Redes Sociales -->
    {team.social && (
      <section class="team-social" style="margin-bottom: 3rem;">
        <h2 style="font-size: 1.75rem; margin-bottom: 1.5rem; border-bottom: 2px solid var(--color-accent); padding-bottom: 0.5rem;">
          📱 Redes Sociales Oficiales
        </h2>
        <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
          {team.social.twitter && (
            <a href={team.social.twitter} target="_blank" class="social-icon" style="width: auto; padding: 0.75rem 1.25rem; border-radius: 8px; background: #1da1f2; color: white; font-weight: 600;">
              Twitter
            </a>
          )}
          {team.social.instagram && (
            <a href={team.social.instagram} target="_blank" class="social-icon" style="width: auto; padding: 0.75rem 1.25rem; border-radius: 8px; background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); color: white; font-weight: 600;">
              Instagram
            </a>
          )}
          {team.social.officialSite && (
            <a href={team.social.officialSite} target="_blank" class="social-icon" style="width: auto; padding: 0.75rem 1.25rem; border-radius: 8px; background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text); font-weight: 600;">
              Sitio Oficial
            </a>
          )}
        </div>
      </section>
    )}

    <!-- Volver a la lista -->
    <div style="text-align: center; margin-top: 3rem;">
      <a href="/equipos" style="display: inline-flex; align-items: center; gap: 0.5rem; color: var(--color-accent); font-weight: 600;">
        ← Volver a todos los equipos
      </a>
    </div>
  </main>
</Layout>