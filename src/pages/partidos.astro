---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { knockoutMatches } from '../lib/tournament';

const allTeams = await getCollection('teams');
const teams = allTeams.sort((a, b) => a.data.name.localeCompare(b.data.name));

const groupedByGroup = teams.reduce((acc, team) => {
  const groupName = team.data.group ? `Grupo ${team.data.group}` : 'Por Definir';
  if (!acc[groupName]) acc[groupName] = [];
  acc[groupName].push(team);
  return acc;
}, {} as Record<string, typeof teams>);

const sortedGroups = Object.entries(groupedByGroup).sort(([a], [b]) => {
  if (a === 'Por Definir') return 1;
  if (b === 'Por Definir') return -1;
  return a.localeCompare(b);
});
---

<Layout title="Partidos - FutbolExperto.com" description="Calendario y seguimiento de partidos del Mundial 2026">
  <main class="container section">
    <div class="page-header">
      <h1>Mapa del Torneo</h1>
      <p class="page-desc">Sigue el camino a la gran final del 2026</p>
    </div>

    <div class="tabs">
      <button class="tab-btn active" data-tab="groups">Fase de Grupos</button>
      <button class="tab-btn" data-tab="bracket">Fase Final (Eliminatorias)</button>
    </div>

    <!-- Grupos Content -->
    <div id="groupsTab" class="tab-content active">
      <div class="groups-container">
        {sortedGroups.map(([groupName, groupTeams]) => (
          <div class="group-box">
            <h3 class="group-title">{groupName}</h3>
            <div class="group-table">
              {groupTeams.map((team, index) => (
                <div class="group-row">
                  <span class="pos">{index + 1}</span>
                  <img src={team.data.flag} alt={team.data.name} class="mini-flag" />
                  <span class="name">{team.data.name}</span>
                  <div class="stats">
                    <span>0 PJ</span>
                    <span class="pts">0 PTS</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Bracket Content -->
    <div id="bracketTab" class="tab-content">
      <div class="bracket-wrapper">
        <div class="bracket">
          <!-- Round of 32 -->
          <div class="bracket-column">
            <h4 class="round-title">Dieciseisavos</h4>
            <div class="round-matches">
              {knockoutMatches.r32.map(match => (
                <div class="match-slot">
                  <div class="match-box card">
                    <div class="match-team">
                      <img src={match.team1?.flag || 'https://placehold.co/40x40?text=?'} alt="" class="flag" />
                      <span class="name">{match.team1?.name || 'TBD'}</span>
                      <span class="score">{match.team1?.score ?? '-'}</span>
                    </div>
                    <div class="match-divider"></div>
                    <div class="match-team">
                      <img src={match.team2?.flag || 'https://placehold.co/40x40?text=?'} alt="" class="flag" />
                      <span class="name">{match.team2?.name || 'TBD'}</span>
                      <span class="score">{match.team2?.score ?? '-'}</span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Connecting Lines R32 -> R16 -->
          <div class="connecting-lines"></div>

          <!-- Round of 16 -->
          <div class="bracket-column">
            <h4 class="round-title">Octavos</h4>
            <div class="round-matches">
              {knockoutMatches.r16.map(match => (
                <div class="match-slot r16-slot">
                  <div class="match-box card">
                    <div class="match-team">
                       <img src={match.team1?.flag || 'https://placehold.co/40x40?text=?'} alt="" class="flag" />
                       <span class="name">{match.team1?.name || 'TBD'}</span>
                    </div>
                    <div class="match-divider"></div>
                    <div class="match-team">
                       <img src={match.team2?.flag || 'https://placehold.co/40x40?text=?'} alt="" class="flag" />
                       <span class="name">{match.team2?.name || 'TBD'}</span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Quarters -->
          <div class="bracket-column">
            <h4 class="round-title">Cuartos</h4>
            <div class="round-matches">
              {knockoutMatches.qf.map(match => (
                <div class="match-slot qf-slot">
                  <div class="match-box card">
                    <div class="match-team">
                       <img src={match.team1?.flag || 'https://placehold.co/40x40?text=?'} alt="" class="flag" />
                       <span class="name">{match.team1?.name || 'TBD'}</span>
                    </div>
                    <div class="match-divider"></div>
                    <div class="match-team">
                       <img src={match.team2?.flag || 'https://placehold.co/40x40?text=?'} alt="" class="flag" />
                       <span class="name">{match.team2?.name || 'TBD'}</span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Semis -->
          <div class="bracket-column">
            <h4 class="round-title">Semis</h4>
            <div class="round-matches">
              {knockoutMatches.sf.map(match => (
                <div class="match-slot sf-slot">
                  <div class="match-box card">
                    <div class="match-team">
                       <img src={match.team1?.flag || 'https://placehold.co/40x40?text=?'} alt="" class="flag" />
                       <span class="name">{match.team1?.name || 'TBD'}</span>
                    </div>
                    <div class="match-divider"></div>
                    <div class="match-team">
                       <img src={match.team2?.flag || 'https://placehold.co/40x40?text=?'} alt="" class="flag" />
                       <span class="name">{match.team2?.name || 'TBD'}</span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Final -->
          <div class="bracket-column">
            <h4 class="round-title">Gran Final</h4>
            <div class="round-matches">
              <div class="match-slot final-slot">
                <div class="match-box card final-box">
                  <div class="winner-icon">🏆</div>
                  <div class="match-team">
                     <img src={knockoutMatches.final[0].team1?.flag || 'https://placehold.co/40x40?text=?'} alt="" class="flag" />
                     <span class="name">{knockoutMatches.final[0].team1?.name || 'FINALISTA 1'}</span>
                  </div>
                  <div class="match-divider"></div>
                  <div class="match-team">
                     <img src={knockoutMatches.final[0].team2?.flag || 'https://placehold.co/40x40?text=?'} alt="" class="flag" />
                     <span class="name">{knockoutMatches.final[0].team2?.name || 'FINALISTA 2'}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('.tab-btn');
      const contents = document.querySelectorAll('.tab-content');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const target = tab.getAttribute('data-tab');
          
          tabs.forEach(t => t.classList.remove('active'));
          contents.forEach(c => c.classList.remove('active'));
          
          tab.classList.add('active');
          document.getElementById(target + 'Tab')?.classList.add('active');
        });
      });
    });
  </script>
</Layout>

<style>
  .page-header { margin-bottom: 2rem; }
  .page-header h1 { font-size: 2.5rem; }

  .tabs {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    border-bottom: 3px solid #000000;
    padding-bottom: 1rem;
  }
  .tab-btn {
    background: #ffffff;
    border: 3px solid #000000;
    padding: 0.75rem 1.5rem;
    font-weight: 800;
    text-transform: uppercase;
    cursor: pointer;
    font-family: inherit;
    transition: transform 0.1s;
  }
  .tab-btn:hover { transform: translate(-3px, -3px); }
  .tab-btn.active {
    background: #000000;
    color: #ffffff;
  }

  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* ===== GROUPS GRID ===== */
  .groups-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .group-box {
    background: #ffffff;
    border: 3px solid #000000;
    padding: 1.25rem;
  }
  .group-title {
    font-size: 1.2rem;
    border-bottom: 3px solid #000000;
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
  }
  .group-table { display: flex; flex-direction: column; gap: 0.5rem; }
  .group-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    font-weight: 700;
  }
  .mini-flag { width: 24px; height: 16px; border: 1px solid #000000; object-fit: cover; }
  .pos { width: 1.5rem; font-weight: 900; }
  .name { flex: 1; text-transform: uppercase; }
  .stats { font-size: 0.75rem; color: #666666; display: flex; gap: 0.75rem; }
  .pts { font-weight: 900; color: #000000; }

  /* ===== BRACKET ===== */
  .bracket-wrapper {
    overflow-x: auto;
    padding: 2rem 0;
    cursor: grab;
  }
  .bracket {
    display: flex;
    gap: 4rem;
    min-width: 1200px;
    padding: 1rem;
  }
  .bracket-column {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .round-title {
    text-align: center;
    text-transform: uppercase;
    font-size: 1.1rem;
    margin-bottom: 2rem;
    border: 3px solid #000000;
    padding: 0.5rem;
  }
  .round-matches {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    gap: 1.5rem;
  }
  .match-slot { position: relative; }
  .match-box {
    background: #ffffff;
    padding: 0.75rem;
    width: 220px;
  }
  .match-team {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 0;
  }
  .match-team .flag { width: 30px; height: 20px; border: 2px solid #000000; }
  .match-team .name { font-size: 0.8rem; font-weight: 800; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .match-team .score { margin-left: auto; font-weight: 900; background: #f0f0f0; padding: 0 0.4rem; border: 2px solid #000000; }
  .match-divider { height: 2px; background: #000000; margin: 0.25rem 0; }

  /* Round spacing adjustments */
  .r16-slot { height: calc(100% / 8); display: flex; align-items: center; }
  .qf-slot { height: calc(100% / 4); display: flex; align-items: center; }
  .sf-slot { height: calc(100% / 2); display: flex; align-items: center; }
  .final-slot { height: 100%; display: flex; align-items: center; }

  .final-box {
    border-color: #000000;
    background: #ffffff;
    border-width: 5px;
    position: relative;
    padding-top: 2rem;
  }
  .winner-icon {
    position: absolute;
    top: -1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 2.5rem;
  }

  @media (max-width: 768px) {
    .tabs { flex-direction: column; }
    .bracket { gap: 2rem; }
  }
</style>
