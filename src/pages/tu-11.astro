---
import Layout from '../layouts/Layout.astro';

export const prerender = false;

const builderSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://futbolexperto.com/' },
        { '@type': 'ListItem', position: 2, name: 'Tu 11', item: 'https://futbolexperto.com/tu-11' },
      ],
    },
    {
      '@type': 'WebPage',
      name: 'Tu 11',
      url: 'https://futbolexperto.com/tu-11',
      description: 'Nuevo desarrollo embebido de Tu 11 en FutbolExperto.',
      inLanguage: 'es',
    },
  ],
};
---

<Layout title="Tu 11 - FutbolExperto" description="Nuevo desarrollo embebido de Tu 11 en FutbolExperto.">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(builderSchema)} />
  </Fragment>

  <main class="container section">
    <section class="coming-hero">
      <div>
        <div class="eyebrow accent-violet">TU 11</div>
        <h1>Tu 11</h1>
        <p class="page-desc">Arma tu equipo ideal y explora la experiencia interactiva directamente desde esta sección.</p>
      </div>
      <div class="hero-note card">
        <strong>Personaliza tu equipo</strong>
        <p>Selecciona, prueba y experimenta con tu once desde este espacio interactivo.</p>
      </div>
    </section>

    <section class="embed-placeholder card">
      <div class="placeholder-head">
        <div>
          <div class="eyebrow">EXPERIENCIA INTERACTIVA</div>
          <h2>Tu 11</h2>
        </div>
      </div>

      <div class="iframe-shell" aria-label="Embed activo de Tu 11">
        <iframe
          class="tu11-iframe"
          src="https://futbol-sim-2d-5676525826.us-west1.run.app"
          title="Tu 11 - simulador embebido"
          loading="lazy"
          referrerpolicy="strict-origin-when-cross-origin"
          allow="clipboard-read; clipboard-write"
        ></iframe>
      </div>

      <div class="placeholder-notes">
        <article class="note-block">
          <strong>Crea tu once</strong>
          <p>Prueba combinaciones, ajusta tu equipo y juega con la experiencia desde este espacio.</p>
        </article>
        <article class="note-block">
          <strong>Comparte tu idea</strong>
          <p>Usa esta sección para explorar alineaciones y construir tu versión ideal.</p>
        </article>
      </div>
    </section>
  </main>
</Layout>

<style>
  .coming-hero {
    display: grid;
    grid-template-columns: 1.2fr 0.9fr;
    gap: 1rem;
    align-items: stretch;
    margin-bottom: 1rem;
  }
  .eyebrow {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.5rem;
  }
  .coming-hero h1 {
    font-size: clamp(2.3rem, 5vw, 4rem);
    margin-bottom: 0.6rem;
  }
  .page-desc {
    color: #333333;
    max-width: 760px;
    font-weight: 600;
  }
  .hero-note {
    padding: 1rem;
    border-color: var(--accent-violet);
    box-shadow: 8px 8px 0 var(--accent-violet-soft);
  }
  .hero-note strong {
    display: block;
    margin-bottom: 0.35rem;
    text-transform: uppercase;
    font-size: 0.9rem;
  }
  .hero-note p {
    color: #333333;
    font-size: 0.92rem;
  }

  .embed-placeholder {
    padding: 1rem;
  }
  .placeholder-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: start;
    margin-bottom: 1rem;
  }
  .placeholder-head h2 {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
  }
  .iframe-shell {
    min-height: 780px;
    border: 3px solid #000000;
    background: #ffffff;
    padding: 0.75rem;
    margin-bottom: 1rem;
    box-shadow: 10px 10px 0 rgba(0,0,0,0.08);
  }
  .tu11-iframe {
    width: 100%;
    min-height: 720px;
    border: 0;
    display: block;
    background: #ffffff;
  }
  .placeholder-notes {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }
  .note-block {
    border: 2px solid #000000;
    background: #ffffff;
    padding: 0.9rem;
  }
  .note-block strong {
    display: block;
    margin-bottom: 0.3rem;
    text-transform: uppercase;
    font-size: 0.85rem;
  }
  .note-block p {
    color: #444444;
    font-size: 0.9rem;
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .coming-hero,
    .placeholder-notes {
      grid-template-columns: 1fr;
    }
    .placeholder-head {
      flex-direction: column;
    }
    .iframe-shell {
      min-height: 560px;
    }
    .tu11-iframe {
      min-height: 520px;
    }
  }
</style>
