---
const { 
  title = 'FutbolExperto - Mundial 2026', 
  description = 'Noticias, partidos y cobertura total en tiempo real de los equipos y jugadores del Mundial 2026 en México, USA y Canadá.',
  image = '/og-image.png',
  type = 'website'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <!-- Google Tag Manager -->
    <script type="text/javascript" is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-W8QJ8Z9T');</script>
    <!-- End Google Tag Manager -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ffffff" />
    
    <!-- SEO Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <!-- GEO / Generative Engine Optimization (JSON-LD) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "FutbolExperto.com",
        "alternateName": "FutbolExperto",
        "url": "https://futbolexperto.com",
        "description": "La plataforma líder en cobertura del Mundial 2026.",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://futbolexperto.com/noticias?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SportsEvent",
        "name": "Copa Mundial de la FIFA 2026",
        "startDate": "2026-06-11",
        "endDate": "2026-07-19",
        "eventStatus": "https://schema.org/EventScheduled",
        "location": [
          { "@type": "Place", "name": "México" },
          { "@type": "Place", "name": "Estados Unidos" },
          { "@type": "Place", "name": "Canadá" }
        ],
        "description": "La XXIII edición de la Copa Mundial de Fútbol masculino organizada por la FIFA."
      }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans+Flex+Text:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Google+Sans+Flex+Text:wght@400;500;600;700;800;900&display=swap');

      :root {
        --color-bg: #ffffff;
        --color-surface: #ffffff;
        --color-surface-2: #f5f5f5;
        --color-border: #000000;
        --color-border-light: #000000;
        --color-text: #000000;
        --color-text-secondary: #333333;
        --color-text-muted: #666666;
        --color-primary: #000000;
        --color-primary-light: #000000;
        --color-primary-glow: transparent;
        --color-accent: #000000;
        --color-accent-glow: transparent;
        --color-warning: #000000;
        --color-warning-glow: transparent;
        --color-danger: #000000;
        --radius-sm: 0px;
        --radius-md: 0px;
        --radius-lg: 0px;
        --radius-xl: 0px;
        --shadow-sm: none;
        --shadow-md: none;
        --shadow-lg: none;
        --shadow-glow: none;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: 'Google Sans Flex Text', 'Google Sans', system-ui, -apple-system, sans-serif;
        background: var(--color-bg);
        color: var(--color-text);
        min-height: 100vh;
        line-height: 1.6;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: 'Google Sans Flex Text', 'Google Sans', sans-serif;
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.15;
        text-transform: uppercase;
      }

      a { color: inherit; text-decoration: none; }
      img { max-width: 100%; display: block; }

      .container {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 1.25rem;
      }

      /* ===== HEADER ===== */
      .header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: #ffffff;
        border-bottom: 3px solid #000000;
      }

      .header-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 64px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: 'Google Sans Flex Text', sans-serif;
        font-size: 1.4rem;
        font-weight: 900;
        color: #000000;
        text-transform: uppercase;
        letter-spacing: -0.02em;
      }

      .logo-icon {
        width: 34px;
        height: 34px;
        background: #ffffff;
        border: 3px solid #000000;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
      }

      .logo span {
        color: #000000;
        background: none;
        -webkit-background-clip: unset;
        background-clip: unset;
      }

      .nav {
        display: flex;
        gap: 0.15rem;
        list-style: none;
      }

      .nav a {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.45rem 0.85rem;
        color: #000000;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        border: 2px solid transparent;
        transition: all 0.1s;
      }

      .nav a:hover {
        border: 2px solid #000000;
        background: #ffffff;
      }

      .nav a.active {
        border: 2px solid #000000;
        background: #ffffff;
        color: #000000;
        text-decoration: underline;
        text-decoration-thickness: 3px;
      }

      .mobile-toggle {
        display: none;
        background: #ffffff;
        border: 3px solid #000000;
        color: #000000;
        font-size: 1.3rem;
        cursor: pointer;
        padding: 0.2rem 0.5rem;
        font-weight: 900;
      }

      /* ===== COMMON ===== */
      .section { padding: 3rem 0; }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.15rem 0.55rem;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        background: #ffffff;
        border: 2px solid #000000;
        color: #000000;
      }

      .card {
        background: #ffffff;
        border: 3px solid #000000;
        overflow: hidden;
        transition: transform 0.1s ease;
      }

      .card:hover {
        transform: translate(-4px, -4px);
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        font-size: 0.85rem;
        font-weight: 800;
        cursor: pointer;
        border: 3px solid #000000;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        transition: all 0.1s;
        font-family: 'Google Sans Flex Text', sans-serif;
        background: #ffffff;
        color: #000000;
      }

      .btn:hover {
        transform: translate(-3px, -3px);
        text-decoration: underline;
        text-decoration-thickness: 2px;
        text-underline-offset: 4px;
      }

      .btn-primary {
        background: #ffffff;
        color: #000000;
        border-width: 4px;
      }

      .btn-ghost {
        background: #ffffff;
        color: #000000;
        border-width: 2px;
      }

      .section-title {
        font-size: 1.5rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-transform: uppercase;
      }

      .section-title::after {
        content: '';
        flex: 1;
        height: 3px;
        background: #000000;
      }

      .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--color-text-muted);
        border: 2px dashed #000000;
      }

      .divider {
        height: 3px;
        background: #000000;
        margin: 2rem 0;
      }

      /* ===== NEWS ITEMS ===== */
      .news-card {
        display: block;
        padding: 1rem 1.25rem;
        background: #ffffff;
        border: 2px solid #000000;
        transition: all 0.1s;
      }

      .news-card:hover {
        transform: translate(-2px, -2px);
        box-shadow: 2px 2px 0px #000000;
      }

      .news-card .title {
        font-weight: 700;
        font-size: 0.95rem;
        margin-bottom: 0.4rem;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .news-card .summary {
        font-size: 0.85rem;
        color: #333333;
        margin-bottom: 0.5rem;
      }

      .news-card .meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.8rem;
        color: #666666;
      }

      .news-card .source {
        color: #000000;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 0.05em;
      }

      .read-more-link {
        color: #000000;
        font-weight: 700;
        font-size: 0.85rem;
        text-decoration: underline;
        text-underline-offset: 3px;
        text-transform: uppercase;
        letter-spacing: 0.03em;
      }

      .read-more-link:hover {
        text-decoration-thickness: 3px;
      }

      /* ===== FOOTER ===== */
      .footer {
        border-top: 3px solid #000000;
        padding: 2rem 0;
        margin-top: 4rem;
      }

      .footer-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .footer-brand {
        font-family: 'Google Sans Flex Text', sans-serif;
        font-weight: 800;
        color: #000000;
        text-transform: uppercase;
      }

      .footer-info {
        font-size: 0.8rem;
        color: #666666;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-weight: 500;
      }

      .footer-info .dot {
        width: 4px;
        height: 4px;
        background: #000000;
      }

      .pulse {
        display: inline-block;
        width: 8px;
        height: 8px;
        background: #000000;
        margin-right: 0.4rem;
        animation: pulse 2s infinite;
      }

      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
      }

      /* ===== RESPONSIVE ===== */
      @media (max-width: 768px) {
        .nav { display: none; }
        .nav.open {
          display: flex;
          flex-direction: column;
          position: absolute;
          top: 64px;
          left: 0;
          right: 0;
          background: #ffffff;
          border-bottom: 3px solid #000000;
          padding: 0.5rem;
        }
        .mobile-toggle { display: block; }
        .footer-inner { flex-direction: column; text-align: center; }
      }
    </style>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W8QJ8Z9T"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <header class="header">
      <div class="container header-inner">
        <a href="/" class="logo">
          <div class="logo-icon">&#9917;</div>
          <span>FutbolExperto.com</span>
        </a>
        <button class="mobile-toggle" id="mobileToggle" aria-label="Menu">&#9776;</button>
        <nav>
          <ul class="nav" id="mainNav">
            <li><a href="/" class:list={[{ active: currentPath === '/' }]}>Inicio</a></li>
            <li><a href="/noticias" class:list={[{ active: currentPath.startsWith('/noticias') }]}>Noticias</a></li>
            <li><a href="/jugadores" class:list={[{ active: currentPath.startsWith('/jugadores') || currentPath.startsWith('/jugador') }]}>Jugadores</a></li>
            <li><a href="/partidos" class:list={[{ active: currentPath.startsWith('/partidos') }]}>Partidos</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="footer">
      <div class="container footer-inner">
        <div class="footer-brand">FutbolExperto.com &copy; 2026</div>
        <div class="footer-info">
          <span><span class="pulse"></span>¡Noticias del mundial actualizadas!</span>
        </div>
      </div>
    </footer>

    <script>
      document.getElementById('mobileToggle')?.addEventListener('click', () => {
        document.getElementById('mainNav')?.classList.toggle('open');
      });
    </script>
  </body>
</html>
