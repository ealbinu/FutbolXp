---
const { 
  title = 'FutbolExperto - Mundial 2026', 
  description = 'Noticias, partidos y cobertura total en tiempo real de los equipos y jugadores del Mundial 2026 en México, USA y Canadá.',
  image = '/og-image.svg',
  type = 'website',
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site || new URL('https://futbolexperto.com');
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const socialImageURL = new URL(image, siteUrl);
const currentPath = Astro.url.pathname;
const robots = noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';
const globalSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://futbolexperto.com/#organization',
      name: 'FutbolExperto',
      url: 'https://futbolexperto.com',
      logo: 'https://futbolexperto.com/og-image.svg',
    },
    {
      '@type': 'WebSite',
      '@id': 'https://futbolexperto.com/#website',
      name: 'FutbolExperto.com',
      alternateName: 'FutbolExperto',
      url: 'https://futbolexperto.com',
      description: 'Cobertura editorial, noticias y análisis del Mundial 2026.',
      publisher: { '@id': 'https://futbolexperto.com/#organization' },
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://futbolexperto.com/noticias?q={search_term_string}',
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'WebPage',
      '@id': `${canonicalURL.toString()}#webpage`,
      url: canonicalURL.toString(),
      name: title,
      description,
      isPartOf: { '@id': 'https://futbolexperto.com/#website' },
      inLanguage: 'es',
    },
    {
      '@type': 'SportsEvent',
      name: 'Copa Mundial de la FIFA 2026',
      startDate: '2026-06-11',
      endDate: '2026-07-19',
      eventStatus: 'https://schema.org/EventScheduled',
      location: [
        { '@type': 'Place', name: 'México' },
        { '@type': 'Place', name: 'Estados Unidos' },
        { '@type': 'Place', name: 'Canadá' },
      ],
      description: 'La XXIII edición de la Copa Mundial de Fútbol masculino organizada por la FIFA.',
    },
  ],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <!-- Google Tag Manager -->
    <script type="text/javascript" is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-W8QJ8Z9T');</script>
    <!-- End Google Tag Manager -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="author" content="FutbolExperto" />
    <meta name="generator" content="Astro" />
    
    <!-- SEO Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="es" href={canonicalURL} />
    <meta name="robots" content={robots} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="FutbolExperto" />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:alt" content={title} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />
    <meta property="twitter:image:alt" content={title} />

    <!-- GEO / Generative Engine Optimization (JSON-LD) -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(globalSchema)} />
    <slot name="head" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans+Flex+Text:wght@400;700;800;900&display=swap" rel="stylesheet" />
    <style is:global>

      :root {
        --color-bg: #ffffff;
        --color-surface: #ffffff;
        --color-surface-2: #f5f5f5;
        --color-border: #000000;
        --color-border-light: #000000;
        --color-text: #000000;
        --color-text-secondary: #333333;
        --color-text-muted: #666666;
        --color-primary: #000000;
        --color-primary-light: #000000;
        --color-primary-glow: transparent;
        --color-accent: #000000;
        --color-accent-glow: transparent;
        --color-warning: #000000;
        --color-warning-glow: transparent;
        --color-danger: #000000;
        --accent-blue: #2563eb;
        --accent-blue-soft: #dbeafe;
        --accent-green: #15803d;
        --accent-green-soft: #dcfce7;
        --accent-amber: #b45309;
        --accent-amber-soft: #fef3c7;
        --accent-rose: #be185d;
        --accent-rose-soft: #fce7f3;
        --accent-violet: #7c3aed;
        --accent-violet-soft: #ede9fe;
        --radius-sm: 0px;
        --radius-md: 0px;
        --radius-lg: 0px;
        --radius-xl: 0px;
        --shadow-sm: none;
        --shadow-md: none;
        --shadow-lg: none;
        --shadow-glow: none;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: 'Google Sans Flex Text', 'Google Sans', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: var(--color-bg);
        color: var(--color-text);
        min-height: 100vh;
        line-height: 1.6;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeSpeed;
        position: relative;
      }

      .site-frame {
        padding-inline: max(1rem, env(safe-area-inset-left), env(safe-area-inset-right));
      }

      @media (max-width: 768px) {
        .site-frame {
          padding-inline: max(1rem, calc(env(safe-area-inset-left) + 0.875rem), calc(env(safe-area-inset-right) + 0.875rem));
        }
      }

      @media (max-width: 480px) {
        .site-frame {
          padding-inline: max(0.875rem, calc(env(safe-area-inset-left) + 0.75rem), calc(env(safe-area-inset-right) + 0.75rem));
        }
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: 'Google Sans Flex Text', 'Google Sans', sans-serif;
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.15;
        text-transform: uppercase;
      }

      a { color: inherit; text-decoration: none; }
      img { max-width: 100%; display: block; }

      .container {
        width: 100%;
        max-width: 1280px;
        margin: 0 auto;
        padding-left: clamp(1.25rem, 2.8vw, 2.75rem);
        padding-right: clamp(1.25rem, 2.8vw, 2.75rem);
      }

      @media (max-width: 1024px) {
        .container {
          padding-left: clamp(1.1rem, 4vw, 1.75rem);
          padding-right: clamp(1.1rem, 4vw, 1.75rem);
        }
      }

      @media (max-width: 768px) {
        .container {
          padding-left: clamp(1rem, 5vw, 1.4rem);
          padding-right: clamp(1rem, 5vw, 1.4rem);
        }
      }

      @media (max-width: 480px) {
        .container {
          padding-left: 1rem;
          padding-right: 1rem;
        }
      }

      /* ===== HEADER ===== */
      .header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: #ffffff;
        border-bottom: 3px solid #000000;
        content-visibility: auto;
      }

      .header-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        height: 64px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: 'Google Sans Flex Text', sans-serif;
        font-size: 1.4rem;
        font-weight: 900;
        color: #000000;
        text-transform: uppercase;
        letter-spacing: -0.02em;
        flex-shrink: 0;
        min-width: 0;
      }

      .logo-icon {
        width: 34px;
        height: 34px;
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        line-height: 1;
        animation: logoBallBounce 2.4s ease-in-out infinite;
        transform-origin: center bottom;
        will-change: transform;
      }

      .logo-text {
        color: #000000;
        background: none;
        -webkit-background-clip: unset;
        background-clip: unset;
      }

      .nav {
        display: flex;
        gap: 0.15rem;
        list-style: none;
        flex-wrap: nowrap;
      }

      .nav a {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.45rem 0.72rem;
        color: #000000;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        border: 2px solid transparent;
        transition: all 0.1s;
        white-space: nowrap;
      }

      .nav a:hover {
        border: 2px solid #000000;
        background: #ffffff;
      }

      .nav a.active {
        border: 2px solid #000000;
        background: #ffffff;
        color: #000000;
        text-decoration: underline;
        text-decoration-thickness: 3px;
      }

      .mobile-toggle {
        display: none;
        background: #ffffff;
        border: 3px solid #000000;
        color: #000000;
        font-size: 1.3rem;
        cursor: pointer;
        padding: 0.2rem 0.5rem;
        font-weight: 900;
      }

      /* ===== COMMON ===== */
      .section { padding: 3rem 0; }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.15rem 0.55rem;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        background: #ffffff;
        border: 2px solid #000000;
        color: #000000;
      }

      .card {
        background: #ffffff;
        border: 3px solid #000000;
        overflow: hidden;
        transition: transform 0.1s ease;
      }

      .card:hover {
        transform: translate(-4px, -4px);
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        font-size: 0.85rem;
        font-weight: 800;
        cursor: pointer;
        border: 3px solid #000000;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        transition: all 0.1s;
        font-family: 'Google Sans Flex Text', sans-serif;
        background: #ffffff;
        color: #000000;
      }

      .btn:hover {
        transform: translate(-3px, -3px);
        text-decoration: underline;
        text-decoration-thickness: 2px;
        text-underline-offset: 4px;
      }

      .btn-primary {
        background: #ffffff;
        color: #000000;
        border-width: 4px;
      }

      .btn-ghost {
        background: #ffffff;
        color: #000000;
        border-width: 2px;
      }

      .section-title {
        font-size: 1.5rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-transform: uppercase;
      }

      .section-title::after {
        content: '';
        flex: 1;
        height: 3px;
        background: #000000;
        box-shadow: 10px 0 0 var(--accent-blue), 20px 0 0 var(--accent-violet);
      }

      .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--color-text-muted);
        border: 2px dashed #000000;
      }

      .divider {
        height: 3px;
        background: #000000;
        margin: 2rem 0;
      }

      /* ===== NEWS ITEMS ===== */
      .news-card {
        display: block;
        padding: 1rem 1.25rem;
        background: #ffffff;
        border: 2px solid #000000;
        transition: all 0.1s;
      }

      .news-card:hover {
        transform: translate(-2px, -2px);
        box-shadow: 2px 2px 0px #000000;
      }

      @media (max-width: 768px) {
        .news-card { padding: 1.25rem 1.5rem; }
      }

      .news-card .title {
        font-weight: 700;
        font-size: 0.95rem;
        margin-bottom: 0.4rem;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .news-card .summary {
        font-size: 0.85rem;
        color: #333333;
        margin-bottom: 0.5rem;
      }

      .news-card .meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.8rem;
        color: #666666;
      }

      .news-card .source {
        color: #000000;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 0.05em;
      }

      .read-more-link {
        color: #000000;
        font-weight: 700;
        font-size: 0.85rem;
        text-decoration: underline;
        text-underline-offset: 3px;
        text-transform: uppercase;
        letter-spacing: 0.03em;
      }

      .read-more-link:hover {
        text-decoration-thickness: 3px;
      }

      /* ===== FOOTER ===== */
      .footer {
        border-top: 3px solid #000000;
        padding: 2rem 0;
        margin-top: 4rem;
      }

      .footer-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .footer-brand {
        font-family: 'Google Sans Flex Text', sans-serif;
        font-weight: 800;
        color: #000000;
        text-transform: uppercase;
      }

      .footer-info {
        font-size: 0.8rem;
        color: #666666;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-weight: 500;
      }

      .footer-info .dot {
        width: 4px;
        height: 4px;
        background: #000000;
      }

      .pulse {
        display: inline-block;
        width: 8px;
        height: 8px;
        background: var(--accent-rose);
        margin-right: 0.4rem;
        animation: pulse 2s infinite;
      }

      .accent-blue { border-color: var(--accent-blue) !important; color: var(--accent-blue) !important; background: var(--accent-blue-soft) !important; }
      .accent-green { border-color: var(--accent-green) !important; color: var(--accent-green) !important; background: var(--accent-green-soft) !important; }
      .accent-amber { border-color: var(--accent-amber) !important; color: var(--accent-amber) !important; background: var(--accent-amber-soft) !important; }
      .accent-rose { border-color: var(--accent-rose) !important; color: var(--accent-rose) !important; background: var(--accent-rose-soft) !important; }
      .accent-violet { border-color: var(--accent-violet) !important; color: var(--accent-violet) !important; background: var(--accent-violet-soft) !important; }

      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
      }

      @keyframes logoBallBounce {
        0%, 100% {
          transform: translateY(0) scaleX(1) scaleY(1);
        }
        8% {
          transform: translateY(0) scaleX(1.06) scaleY(0.94);
        }
        18% {
          transform: translateY(-3px) scaleX(0.97) scaleY(1.04);
        }
        28% {
          transform: translateY(0) scaleX(1.04) scaleY(0.96);
        }
        36% {
          transform: translateY(-1px) scaleX(0.99) scaleY(1.01);
        }
        44% {
          transform: translateY(0) scaleX(1) scaleY(1);
        }
      }

      @media (max-width: 1100px) {
        .logo {
          font-size: 1.22rem;
        }
        .logo-dotcom {
          display: none;
        }
        .nav a {
          padding: 0.4rem 0.58rem;
          font-size: 0.76rem;
          letter-spacing: 0.02em;
        }
      }

      @media (max-width: 920px) {
        .nav { display: none; }
        .nav.open {
          display: flex;
          flex-direction: column;
          position: absolute;
          top: 64px;
          left: 0;
          right: 0;
          background: #ffffff;
          border-bottom: 3px solid #000000;
          padding: 0.5rem;
        }
        .mobile-toggle { display: block; }
      }

      /* ===== RESPONSIVE ===== */
      @media (max-width: 768px) {
        .footer-inner { flex-direction: column; text-align: center; }
        .btn {
          width: 100%;
          justify-content: center;
        }
        .card,
        .news-card,
        .empty-state {
          overflow: hidden;
        }
      }
    </style>
  </head>
  <body>
    <div class="site-frame">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W8QJ8Z9T"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <header class="header">
      <div class="container header-inner">
        <a href="/" class="logo" aria-label="FutbolExperto.com">
          <div class="logo-icon">&#9917;</div>
          <span class="logo-text">FutbolExperto<span class="logo-dotcom">.com</span></span>
        </a>
        <button class="mobile-toggle" id="mobileToggle" aria-label="Menu">&#9776;</button>
        <nav>
          <ul class="nav" id="mainNav">
            <li><a href="/" class:list={[{ active: currentPath === '/' }]}>Inicio</a></li>
            <li><a href="/noticias" class:list={[{ active: currentPath.startsWith('/noticias') }]}>Noticias</a></li>
            <li><a href="/analista" class:list={[{ active: currentPath.startsWith('/analista') }]}>Analista</a></li>
            <li><a href="/jugadores" class:list={[{ active: currentPath.startsWith('/jugadores') || currentPath.startsWith('/jugador') }]}>Jugadores</a></li>
            <li><a href="/partidos" class:list={[{ active: currentPath.startsWith('/partidos') }]}>Partidos</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="footer">
      <div class="container footer-inner">
        <div class="footer-brand">FutbolExperto.com &copy; 2026</div>
        <div class="footer-info">
          <span><span class="pulse"></span>¡Noticias del mundial actualizadas!</span>
        </div>
      </div>
    </footer>

    <script>
      document.getElementById('mobileToggle')?.addEventListener('click', () => {
        document.getElementById('mainNav')?.classList.toggle('open');
      });
    </script>
    </div>
  </body>
</html>
