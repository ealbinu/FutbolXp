			:root {
				--color-bg: #0a0a0a;
				--color-surface: #141414;
				--color-border: #262626;
				--color-text: #f5f5f5;
				--color-text-muted: #a3a3a3;
				--color-accent: #00d4ff;
				--color-accent-glow: rgba(0, 212, 255, 0.3);
				--color-warning: #ffaa00;
				--gradient-mundial: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);
				--gradient-card: linear-gradient(145deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%);
			}
			
			* { margin: 0; padding: 0; box-sizing: border-box; }
			
			body {
				font-family: 'Inter', system-ui, sans-serif;
				background: var(--gradient-mundial);
				color: var(--color-text);
				min-height: 100vh;
				line-height: 1.6;
				overflow-x: hidden;
			}
			
			h1, h2, h3, h4, h5, h6 {
				font-family: 'Playfair Display', serif;
				font-weight: 800;
				letter-spacing: -0.02em;
			}
			
			a { color: inherit; text-decoration: none; }
			
			.container {
