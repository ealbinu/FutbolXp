			}
			
			.news-meta {
				font-size: 0.875rem;
				color: var(--color-text-muted);
				display: flex;
				justify-content: space-between;
			}
			
			/* Player Card */
			.player-card {
				display: flex;
				align-items: center;
				gap: 1rem;
				padding: 1rem;
				background: rgba(255,255,255,0.02);
				border-radius: 8px;
				margin-bottom: 0.75rem;
				border: 1px solid var(--color-border);
				transition: all 0.2s;
			}
			
			.player-card:hover {
				border-color: var(--color-accent);
				background: rgba(0, 212, 255, 0.05);
			}
			
			.player-avatar {
				width: 48px;
				height: 48px;
				border-radius: 50%;
				background: var(--color-surface);
			}
			
			.player-info {
				flex: 1;
			}
			
			.player-name {
				font-weight: 600;
				font-size: 0.95rem;
			}
			
			.player-position {
				font-size: 0.8rem;
				color: var(--color-text-muted);
			}
			
			.social-links {
				display: flex;
				gap: 0.5rem;
			}
			
			.social-icon {
				width: 32px;
				height: 32px;
				border-radius: 6px;
				background: var(--color-surface);
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 0.75rem;
				color: var(--color-text-muted);
