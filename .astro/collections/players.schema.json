{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    }
  },
  "additionalProperties": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "team": {
        "type": "string"
      },
      "position": {
        "type": "string"
      },
      "number": {
        "type": "number"
      },
      "photo": {
        "type": "string"
      },
      "nationality": {
        "type": "string"
      },
      "birth": {
        "type": "string"
      },
      "social": {
        "default": {},
        "type": "object",
        "properties": {
          "twitter": {
            "type": "string"
          },
          "instagram": {
            "type": "string"
          },
          "tiktok": {
            "type": "string"
          },
          "facebook": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "news": {
        "default": [],
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "source": {
              "type": "string"
            },
            "published": {
              "type": "string"
            }
          },
          "required": [
            "title",
            "url",
            "source",
            "published"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "id",
      "name",
      "team",
      "position",
      "nationality",
      "social",
      "news"
    ],
    "additionalProperties": false
  }
}